<script>
  /* Hero form */
  const heroForm = document.getElementById('ind-hero-form') as HTMLFormElement | null;
  const heroMsg  = document.getElementById('ind-hero-msg') as HTMLElement | null;

  heroForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = heroForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.textContent = 'Sending...';
    btn.disabled = true;
    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(Object.fromEntries(new FormData(heroForm))),
      });
      const data = await res.json();
      if (data.success) {
        heroMsg!.textContent = 'Thank you! We will contact you within 24 hours.';
        heroMsg!.className = 'form-msg success';
        heroForm.reset();
      } else { throw new Error(); }
    } catch {
      heroMsg!.textContent = 'Something went wrong. Please call us directly.';
      heroMsg!.className = 'form-msg error';
    } finally {
      heroMsg!.style.display = 'block';
      btn.textContent = 'Get Free Strategy Call';
      btn.disabled = false;
    }
  });

  /* CTA form */
  const ctaForm = document.getElementById('ind-cta-form') as HTMLFormElement | null;
  const ctaMsg  = document.getElementById('ind-cta-msg') as HTMLElement | null;

  ctaForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = ctaForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.textContent = 'Sending...';
    btn.disabled = true;
    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(Object.fromEntries(new FormData(ctaForm))),
      });
      const data = await res.json();
      if (data.success) {
        ctaMsg!.textContent = 'Thank you! We will contact you within 24 hours.';
        ctaMsg!.className = 'form-msg success';
        ctaForm.reset();
      } else { throw new Error(); }
    } catch {
      ctaMsg!.textContent = 'Something went wrong. Please call us directly.';
      ctaMsg!.className = 'form-msg error';
    } finally {
      ctaMsg!.style.display = 'block';
      btn.textContent = 'Send My Enquiry';
      btn.disabled = false;
    }
  });

  /* FAQ accordion */
  document.querySelectorAll<HTMLButtonElement>('.ind-faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.ind-faq-item')!;
      const answer = item.querySelector<HTMLElement>('.ind-faq-a')!;
      const isOpen = item.classList.contains('open');
      // close all
      document.querySelectorAll('.ind-faq-item').forEach(el => {
        el.classList.remove('open');
        (el.querySelector('.ind-faq-a') as HTMLElement).hidden = true;
        (el.querySelector('.ind-faq-q') as HTMLButtonElement).setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('open');
        answer.hidden = false;
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  /* Scroll reveal */
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

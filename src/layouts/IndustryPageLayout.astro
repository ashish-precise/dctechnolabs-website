---
/**
 * IndustryPageLayout.astro
 * Reusable 12-section layout for all 14 DC technolabs industry sub-pages.
 * Uses PageLayout (BaseLayout + Header + Footer + global.css) as the outer wrapper.
 *
 * Section map:
 *  S1  Hero + embedded form
 *  S2  Industry overview (3 highlight cards)
 *  S3  Challenges (dark — 6 pain points)
 *  S4  Services for this industry (6-8 cards)
 *  S5  Our process (4-5 steps)
 *  S6  Stats bar (dark)
 *  S7  Why choose us (4-6 cards)
 *  S8  Case study (dark)
 *  S9  Testimonials
 *  S10 Pricing (3 tiers)
 *  S11 FAQ accordion (dark)
 *  S12 Final CTA + form
 */

import PageLayout from './PageLayout.astro';

export interface OverviewPoint  { emoji: string; title: string; desc: string }
export interface Challenge      { problem: string; solution: string }
export interface ServiceCard    { icon: string; title: string; desc: string }
export interface ProcessStep    { title: string; desc: string }
export interface StatItem       { value: string; label: string }
export interface WhyCard        { emoji: string; title: string; desc: string }
export interface CaseStudyResult{ value: string; label: string }
export interface CaseStudy      { tag: string; title: string; challenge: string; solution: string; results: CaseStudyResult[] }
export interface Testimonial    { text: string; name: string; role: string; initials: string }
export interface PricingTier    { name: string; price: string; note: string; desc: string; features: string[]; btnLabel: string; btnClass: string; featured?: boolean }
export interface FaqItem        { q: string; a: string }

interface Props {
  title: string;
  description: string;
  canonical: string;
  schemaJson: string;

  /* Hero */
  badge: string;
  heroH1: string;
  heroHighlight: string;
  heroDesc: string;
  heroStats: StatItem[];
  formTitle: string;
  formSub: string;

  /* S2 Overview */
  s2Label?: string;
  s2Title: string;
  s2Subtitle?: string;
  overviewPoints: OverviewPoint[];

  /* S3 Challenges */
  s3Label?: string;
  s3Title: string;
  s3Subtitle?: string;
  challenges: Challenge[];

  /* S4 Services */
  s4Label?: string;
  s4Title: string;
  s4Subtitle?: string;
  services: ServiceCard[];

  /* S5 Process */
  s5Label?: string;
  s5Title: string;
  processSteps: ProcessStep[];

  /* S6 Stats */
  statsHeading?: string;
  stats: StatItem[];

  /* S7 Why Us */
  s7Label?: string;
  s7Title: string;
  s7Subtitle?: string;
  whyCards: WhyCard[];

  /* S8 Case Study */
  caseStudy: CaseStudy;

  /* S9 Testimonials */
  s9Label?: string;
  s9Title: string;
  testimonials: Testimonial[];

  /* S10 Pricing */
  s10Label?: string;
  s10Title: string;
  s10Subtitle?: string;
  pricingTiers: PricingTier[];

  /* S11 FAQ */
  s11Label?: string;
  s11Title: string;
  faqItems: FaqItem[];

  /* S12 CTA */
  ctaTitle: string;
  ctaSubtitle: string;
}

const {
  title, description, canonical, schemaJson,
  badge, heroH1, heroHighlight, heroDesc, heroStats,
  formTitle, formSub,
  s2Label = "Industry Overview", s2Title, s2Subtitle, overviewPoints,
  s3Label = "Common Challenges", s3Title, s3Subtitle = "Sound familiar? You are not alone. These are the pain points we solve every week for businesses in your sector.", challenges,
  s4Label = "What We Offer", s4Title, s4Subtitle = "Every service is tailored to how your industry sells, complies, and grows.", services,
  s5Label = "How We Work", s5Title, processSteps,
  statsHeading, stats,
  s7Label = "Why Choose Us", s7Title, s7Subtitle, whyCards,
  caseStudy,
  s9Label = "Client Reviews", s9Title, testimonials,
  s10Label = "Investment", s10Title, s10Subtitle = "Transparent, fixed pricing. No hidden fees. Every package includes onboarding, strategy, and ongoing support.", pricingTiers,
  s11Label = "FAQ", s11Title, faqItems,
  ctaTitle, ctaSubtitle,
} = Astro.props;

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
});
---

<PageLayout title={title} description={description} canonical={canonical}>

  <!-- Schema -->
  <script type="application/ld+json" set:html={schemaJson} slot="head" />
  <script type="application/ld+json" set:html={faqSchema} slot="head" />

  <!-- ═══════════════════════════════════════════════
       S1: HERO + FORM
  ═══════════════════════════════════════════════ -->
  <section class="ind-hero" id="hero-form">
    <div class="container">
      <div class="ind-hero-grid">

        <!-- Left: content -->
        <div class="ind-hero-content">
          <span class="ind-badge">{badge}</span>
          <h1>{heroH1} <span class="ind-highlight">{heroHighlight}</span></h1>
          <p class="ind-hero-desc">{heroDesc}</p>
          <div class="ind-hero-stats">
            {heroStats.map(s => (
              <div class="ind-hero-stat">
                <strong>{s.value}</strong>
                <span>{s.label}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: form -->
        <div class="ind-form-card">
          <p class="ind-form-title">{formTitle}</p>
          <p class="ind-form-sub">{formSub}</p>
          <form id="ind-hero-form" class="ind-form">
            <input type="hidden" name="access_key" value="0141be72-7ed9-4e67-bd38-e0154c164ba6" />
            <input type="hidden" name="subject" value="New Industry Page Enquiry" />
            <div class="form-row">
              <div class="form-group">
                <label for="ind-name">Your Name</label>
                <input type="text" id="ind-name" name="name" class="form-input" placeholder="Rajesh Patel" required />
              </div>
              <div class="form-group">
                <label for="ind-phone">Phone Number</label>
                <input type="tel" id="ind-phone" name="phone" class="form-input" placeholder="+91 98765 43210" required />
              </div>
            </div>
            <div class="form-group">
              <label for="ind-email">Email Address</label>
              <input type="email" id="ind-email" name="email" class="form-input" placeholder="you@yourcompany.com" required />
            </div>
            <div class="form-group">
              <label for="ind-service">What Do You Need?</label>
              <select id="ind-service" name="service" class="form-input">
                <option value="">Select a service</option>
                <option>Website Design</option>
                <option>SEO Services</option>
                <option>Google Ads / PPC</option>
                <option>Social Media Marketing</option>
                <option>E-commerce Development</option>
                <option>Full Digital Marketing Package</option>
              </select>
            </div>
            <div class="form-group">
              <label for="ind-msg">Tell Us About Your Business</label>
              <textarea id="ind-msg" name="message" class="form-input" rows="3" placeholder="Brief description of your business and goals..." required></textarea>
            </div>
            <button type="submit" class="btn btn-primary form-submit">Get Free Strategy Call</button>
            <div id="ind-hero-msg" class="form-msg" style="display:none"></div>
          </form>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       S2: INDUSTRY OVERVIEW
  ═══════════════════════════════════════════════ -->
  <section class="ind-overview reveal">
    <div class="container">
      <div class="section-header centered">
        <span class="section-label">{s2Label}</span>
        <h2 class="section-title">{s2Title}</h2>
        {s2Subtitle && <p class="section-subtitle">{s2Subtitle}</p>}
      </div>
      <div class="ind-overview-grid">
        {overviewPoints.map(p => (
          <div class="ind-overview-card">
            <div class="ind-overview-emoji">{p.emoji}</div>
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       S3: CHALLENGES (DARK)
  ═══════════════════════════════════════════════ -->
  <section class="ind-challenges reveal">
    <div class="container">
      <div class="section-header centered">
        <span class="section-label" style="color:var(--blue-300)">{s3Label}</span>
        <h2 class="section-title" style="color:var(--white)">{s3Title}</h2>
        <p class="section-subtitle" style="color:var(--gray-400)">{s3Subtitle}</p>
      </div>
      <div class="ind-challenges-grid">
        {challenges.map(c => (
          <div class="ind-challenge-card">
            <div class="ind-challenge-problem">
              <span class="ind-x">✕</span>
              <span>"{c.problem}"</span>
            </div>
            <div class="ind-challenge-solution">
              <span class="ind-check">✓</span>
              <span>{c.solution}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       S4: SERVICES FOR THIS INDUSTRY
  ═══════════════════════════════════════════════ -->
  <section class="ind-services reveal">
    <div class="container">
      <div class="section-header centered">
        <span class="section-label">{s4Label}</span>
        <h2 class="section-title">{s4Title}</h2>
        {s4Subtitle && <p class="section-subtitle">{s4Subtitle}</p>}
      </div>
      <div class="ind-services-grid">
        {services.map(s => (
          <div class="ind-service-card">
            <div class="ind-service-icon" set:html={s.icon} />
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       S5: OUR PROCESS
  ═══════════════════════════════════════════════ -->
  <section class="ind-process reveal">
    <div class="container">
      <div class="section-header centered">
        <span class="section-label">{s5Label}</span>
        <h2 class="section-title">{s5Title}</h2>
      </div>
      <div class="ind-process-steps" style={`--cols:${processSteps.length}`}>
        {processSteps.map((step, i) => (
          <div class="ind-process-step">
            <div class="ind-process-num">{i + 1}</div>
            <h3>{step.title}</h3>
            <p>{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       S6: STATS BAR (DARK)
  ═══════════════════════════════════════════════ -->
  <section class="ind-stats reveal">
    <div class="container">
      {statsHeading && <h2 class="ind-stats-heading">{statsHeading}</h2>}
      <div class="ind-stats-grid">
        {stats.map(s => (
          <div class="ind-stat-item">
            <div class="ind-stat-num">{s.value}</div>
            <div class="ind-stat-label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       S7: WHY CHOOSE US
  ═══════════════════════════════════════════════ -->
  <section class="ind-why reveal">
    <div class="container">
      <div class="section-header centered">
        <span class="section-label">{s7Label}</span>
        <h2 class="section-title">{s7Title}</h2>
        {s7Subtitle && <p class="section-subtitle">{s7Subtitle}</p>}
      </div>
      <div class="ind-why-grid">
        {whyCards.map(c => (
          <div class="ind-why-card">
            <div class="ind-why-emoji">{c.emoji}</div>
            <h3>{c.title}</h3>
            <p>{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       S8: CASE STUDY (DARK)
  ═══════════════════════════════════════════════ -->
  <section class="ind-case reveal">
    <div class="container">
      <div class="ind-case-grid">
        <div class="ind-case-content">
          <span class="ind-case-tag">{caseStudy.tag}</span>
          <h2>{caseStudy.title}</h2>
          <div class="ind-case-block">
            <h4>The Challenge</h4>
            <p>{caseStudy.challenge}</p>
          </div>
          <div class="ind-case-block">
            <h4>What We Did</h4>
            <p>{caseStudy.solution}</p>
          </div>
        </div>
        <div class="ind-case-results">
          <h4 class="ind-case-results-heading">Results Delivered</h4>
          {caseStudy.results.map(r => (
            <div class="ind-case-result-item">
              <div class="ind-case-result-val">{r.value}</div>
              <div class="ind-case-result-label">{r.label}</div>
            </div>
          ))}
          <a href="/contact" class="btn btn-outline-light ind-case-cta">Start Your Project</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       S9: TESTIMONIALS
  ═══════════════════════════════════════════════ -->
  <section class="ind-testimonials reveal">
    <div class="container">
      <div class="section-header centered">
        <span class="section-label">{s9Label}</span>
        <h2 class="section-title">{s9Title}</h2>
      </div>
      <div class="ind-testi-grid">
        {testimonials.map(t => (
          <div class="ind-testi-card">
            <div class="ind-testi-stars">★★★★★</div>
            <p class="ind-testi-text">"{t.text}"</p>
            <div class="ind-testi-author">
              <div class="ind-testi-avatar">{t.initials}</div>
              <div>
                <div class="ind-testi-name">{t.name}</div>
                <div class="ind-testi-role">{t.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       S10: PRICING
  ═══════════════════════════════════════════════ -->
  <section class="ind-pricing reveal">
    <div class="container">
      <div class="section-header centered">
        <span class="section-label">{s10Label}</span>
        <h2 class="section-title">{s10Title}</h2>
        <p class="section-subtitle">{s10Subtitle}</p>
      </div>
      <div class="ind-pricing-grid">
        {pricingTiers.map(tier => (
          <div class:list={["ind-pricing-card", { featured: tier.featured }]}>
            {tier.featured && <div class="ind-pricing-badge">Most Popular</div>}
            <h3>{tier.name}</h3>
            <p class="ind-pricing-desc">{tier.desc}</p>
            <div class="ind-pricing-price">{tier.price}</div>
            <p class="ind-pricing-note">{tier.note}</p>
            <ul class="ind-pricing-features">
              {tier.features.map(f => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href="/contact" class:list={["btn", tier.btnClass, "ind-pricing-btn"]}>
              {tier.btnLabel}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       S11: FAQ (DARK)
  ═══════════════════════════════════════════════ -->
  <section class="ind-faq reveal">
    <div class="container">
      <div class="section-header centered">
        <span class="section-label" style="color:var(--blue-300)">{s11Label}</span>
        <h2 class="section-title" style="color:var(--white)">{s11Title}</h2>
      </div>
      <div class="ind-faq-list">
        {faqItems.map((item, i) => (
          <div class="ind-faq-item" id={`ind-faq-${i}`}>
            <button class="ind-faq-q" aria-expanded="false" aria-controls={`ind-faq-a-${i}`}>
              <span>{item.q}</span>
              <svg class="ind-faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="ind-faq-a" id={`ind-faq-a-${i}`} hidden>
              <p>{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       S12: FINAL CTA + FORM
  ═══════════════════════════════════════════════ -->
  <section class="ind-cta reveal">
    <div class="container">
      <div class="ind-cta-grid">

        <div class="ind-cta-content">
          <h2>{ctaTitle}</h2>
          <p>{ctaSubtitle}</p>
          <div class="ind-cta-points">
            <div class="ind-cta-point"><span class="ind-check-blue">✓</span> Free strategy consultation</div>
            <div class="ind-cta-point"><span class="ind-check-blue">✓</span> Custom proposal within 24 hours</div>
            <div class="ind-cta-point"><span class="ind-check-blue">✓</span> No obligation, no pushy sales</div>
            <div class="ind-cta-point"><span class="ind-check-blue">✓</span> Local team based in Ahmedabad</div>
          </div>
        </div>

        <div class="ind-form-card ind-cta-form-card">
          <p class="ind-form-title">Book Your Free Call</p>
          <form id="ind-cta-form" class="ind-form">
            <input type="hidden" name="access_key" value="0141be72-7ed9-4e67-bd38-e0154c164ba6" />
            <input type="hidden" name="subject" value="New Industry Page CTA Enquiry" />
            <div class="form-group">
              <input type="text" name="name" class="form-input" placeholder="Your Name" required />
            </div>
            <div class="form-group">
              <input type="tel" name="phone" class="form-input" placeholder="Phone Number" required />
            </div>
            <div class="form-group">
              <input type="email" name="email" class="form-input" placeholder="Email Address" required />
            </div>
            <div class="form-group">
              <textarea name="message" class="form-input" rows="3" placeholder="What do you need help with?" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary form-submit">Send My Enquiry</button>
            <div id="ind-cta-msg" class="form-msg" style="display:none"></div>
          </form>
        </div>

      </div>
    </div>
  </section>

</PageLayout>

<style>
/* ═══ S1: HERO ═══════════════════════════════════════════════════════════════ */
.ind-hero {
  padding: 120px 0 clamp(3rem, 6vw, 5rem);
  background: linear-gradient(170deg, var(--white) 0%, var(--blue-50) 55%, var(--white) 100%);
  position: relative;
  overflow: hidden;
}
.ind-hero::before {
  content: '';
  position: absolute;
  top: -150px; right: -150px;
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(59,130,246,.07) 0%, transparent 70%);
  border-radius: 50%;
}
.ind-hero-grid {
  display: grid;
  grid-template-columns: 1fr 420px;
  gap: 3.5rem;
  align-items: center;
  position: relative;
  z-index: 1;
}
.ind-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 16px;
  background: var(--blue-50);
  border: 1px solid var(--blue-200);
  border-radius: 9999px;
  font-family: var(--font-display);
  font-size: .9rem;
  font-weight: 600;
  color: var(--blue-700);
  margin-bottom: 1.25rem;
}
.ind-hero-content h1 {
  font-size: clamp(2.25rem, 4.5vw, 3.25rem);
  letter-spacing: -.03em;
  line-height: 1.1;
  margin-bottom: 1rem;
  color: var(--gray-900);
}
.ind-highlight {
  background: linear-gradient(135deg, var(--blue-600), var(--blue-400));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.ind-hero-desc {
  font-size: 1.1rem;
  color: var(--gray-500);
  line-height: 1.75;
  margin-bottom: 2rem;
  max-width: 520px;
}
.ind-hero-stats {
  display: flex;
  gap: 0;
}
.ind-hero-stat {
  padding-right: 2rem;
  margin-right: 2rem;
  border-right: 1px solid var(--gray-200);
}
.ind-hero-stat:last-child { padding-right: 0; margin-right: 0; border-right: none; }
.ind-hero-stat strong {
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--blue-600);
  display: block;
}
.ind-hero-stat span { font-size: .9rem; color: var(--gray-400); }

/* Form card */
.ind-form-card {
  background: var(--white);
  border-radius: 20px;
  padding: 2rem;
  box-shadow: 0 20px 60px rgba(0,0,0,.08), 0 1px 3px rgba(0,0,0,.04);
  border: 1px solid var(--gray-100);
}
.ind-form-title {
  font-family: var(--font-display);
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--gray-900);
  margin-bottom: .25rem;
}
.ind-form-sub { font-size: .9rem; color: var(--gray-400); margin-bottom: 1.5rem; }
.ind-form .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; }
.form-group { margin-bottom: .875rem; }
.form-group label {
  display: block;
  font-family: var(--font-display);
  font-size: .82rem;
  font-weight: 600;
  color: var(--gray-600);
  margin-bottom: 5px;
}
.form-input {
  width: 100%;
  padding: 11px 14px;
  border: 1.5px solid var(--gray-200);
  border-radius: 10px;
  font-family: var(--font-body);
  font-size: .9rem;
  color: var(--gray-800);
  background: var(--gray-50);
  transition: all .2s;
}
.form-input:focus {
  outline: none;
  border-color: var(--blue-500);
  background: var(--white);
  box-shadow: 0 0 0 3px rgba(59,130,246,.1);
}
.form-input::placeholder { color: var(--gray-400); }
textarea.form-input { resize: vertical; min-height: 80px; }
.form-submit {
  width: 100%;
  padding: 14px;
  margin-top: .25rem;
}
.form-msg {
  margin-top: .75rem;
  padding: .875rem 1rem;
  border-radius: 10px;
  font-size: .875rem;
  font-weight: 500;
  text-align: center;
}
.form-msg.success { background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; }
.form-msg.error   { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }

/* ═══ S2: OVERVIEW ══════════════════════════════════════════════════════════ */
.ind-overview { padding: var(--section-pad) 0; }
.ind-overview-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
.ind-overview-card {
  background: var(--white);
  border: 1.5px solid var(--gray-100);
  border-radius: 16px;
  padding: 2rem;
  transition: all .3s;
  position: relative;
  overflow: hidden;
}
.ind-overview-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;

<script>
  // FAQ accordion
  document.querySelectorAll('.nb-faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.parentElement as HTMLElement;
      const ans = item.querySelector('.nb-faq-ans') as HTMLElement;
      const isOpen = item.classList.contains('nb-open');
      document.querySelectorAll('.nb-faq-item').forEach(i => {
        i.classList.remove('nb-open');
        (i.querySelector('.nb-faq-ans') as HTMLElement).style.maxHeight = '0px';
      });
      if (!isOpen) {
        item.classList.add('nb-open');
        ans.style.maxHeight = ans.scrollHeight + 'px';
      }
    });
  });

  // Scroll reveal
  if ('IntersectionObserver' in window) {
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('nb-visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.nb-reveal').forEach(el => obs.observe(el));
  } else {
    document.querySelectorAll('.nb-reveal').forEach(el => el.classList.add('nb-visible'));
  }

  // Web3Forms - Hero form
  const nbHeroForm = document.getElementById('nbHeroForm') as HTMLFormElement | null;
  const nbHeroMsg = document.getElementById('nbHeroFormMsg') as HTMLElement | null;
  if (nbHeroForm && nbHeroMsg) {
    nbHeroForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = nbHeroForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (btn) btn.disabled = true;
      nbHeroMsg.style.display = 'none';
      try {
        const res = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: new FormData(nbHeroForm) });
        const data = await res.json();
        if (data.success) {
          if (typeof gtag !== 'undefined') { gtag('event', 'generate_lead'); }
          nbHeroMsg.textContent = 'Thank you! We will get back to you within 24 hours.';
          nbHeroMsg.className = 'nb-form-msg nb-form-msg--success';
          nbHeroMsg.style.display = 'block';
          nbHeroForm.reset();
        } else { throw new Error(); }
      } catch {
        nbHeroMsg.textContent = 'Something went wrong. Please WhatsApp us directly.';
        nbHeroMsg.className = 'nb-form-msg nb-form-msg--error';
        nbHeroMsg.style.display = 'block';
      } finally {
        if (btn) btn.disabled = false;
      }
    });
  }

  // Web3Forms - CTA form
  const nbCtaForm = document.getElementById('nbCtaForm') as HTMLFormElement | null;
  const nbCtaMsg = document.getElementById('nbCtaFormMsg') as HTMLElement | null;
  if (nbCtaForm && nbCtaMsg) {
    nbCtaForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = nbCtaForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (btn) btn.disabled = true;
      nbCtaMsg.style.display = 'none';
      try {
        const res = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: new FormData(nbCtaForm) });
        const data = await res.json();
        if (data.success) {
          if (typeof gtag !== 'undefined') { gtag('event', 'generate_lead'); }
          nbCtaMsg.textContent = 'Thank you! We will get back to you within 24 hours.';
          nbCtaMsg.style.display = 'block';
          nbCtaForm.reset();
        } else { throw new Error(); }
      } catch {
        nbCtaMsg.textContent = 'Something went wrong. Please call us directly.';
        nbCtaMsg.style.background = 'rgba(239,68,68,.15)';
        nbCtaMsg.style.color = '#fca5a5';
        nbCtaMsg.style.display = 'block';
      } finally {
        if (btn) btn.disabled = false;
      }
    });
  }
</script>

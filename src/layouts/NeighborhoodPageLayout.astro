---
/**
 * NeighborhoodPageLayout.astro
 * ──────────────────────────────────────────────────────────────────────────────
 * Reusable 12-section layout for Ahmedabad neighborhood sub-pages.
 * Uses PageLayout (BaseLayout + Header + Footer + global.css) as outer wrapper.
 *
 * Section map:
 *  S1   Hero + embedded form
 *  S2   Neighborhood overview (what the area is, business types)
 *  S3   Services for this area (dark)
 *  S4   Local business challenges (6 cards)
 *  S5   Why choose us for [Neighborhood] (6 cards, blue-50)
 *  S6   Our process (dark)
 *  S7   Stats bar
 *  S8   Testimonials
 *  S9   Nearby areas we also serve (dark)
 *  S10  FAQ accordion
 *  S11  Internal links (back to Ahmedabad + related neighborhoods)
 *  S12  Final CTA + form
 */

import PageLayout from './PageLayout.astro';

export interface ServiceCard  { icon: string; title: string; desc: string }
export interface Challenge    { problem: string; solution: string }
export interface WhyCard      { emoji: string; title: string; desc: string }
export interface ProcessStep  { step: string; title: string; desc: string }
export interface StatItem     { value: string; label: string }
export interface Testimonial  { text: string; name: string; role: string; initials: string }
export interface NearbyArea   { name: string; slug: string; desc: string }
export interface FaqItem      { q: string; a: string }
export interface NeighborhoodLink { name: string; slug: string }

interface Props {
  title: string;
  description: string;
  canonical: string;
  schemaJson: string;

  /* Hero */
  badge: string;
  heroH1: string;
  heroHighlight: string;
  heroDesc: string;
  heroStats: StatItem[];
  formTitle: string;
  formSub: string;

  /* S2 Overview */
  s2Label?: string;
  s2Title: string;
  s2Subtitle?: string;
  s2Body: string[];
  businessTypes: { icon: string; label: string }[];
  overviewCards: { icon: string; title: string; desc: string }[];

  /* S3 Services (dark) */
  s3Label?: string;
  s3Title: string;
  s3Subtitle?: string;
  services: ServiceCard[];

  /* S4 Challenges */
  s4Label?: string;
  s4Title: string;
  s4Subtitle?: string;
  challenges: Challenge[];

  /* S5 Why Us */
  s5Label?: string;
  s5Title: string;
  s5Subtitle?: string;
  whyCards: WhyCard[];

  /* S6 Process (dark) */
  s6Label?: string;
  s6Title: string;
  processSteps: ProcessStep[];

  /* S7 Stats */
  statsHeading?: string;
  stats: StatItem[];

  /* S8 Testimonials */
  s8Label?: string;
  s8Title: string;
  testimonials: Testimonial[];

  /* S9 Nearby Areas (dark) */
  s9Label?: string;
  s9Title: string;
  s9Subtitle?: string;
  nearbyAreas: NearbyArea[];

  /* S10 FAQ */
  s10Label?: string;
  s10Title: string;
  faqItems: FaqItem[];

  /* S11 Internal Nav */
  otherNeighborhoods: NeighborhoodLink[];

  /* City context (optional — defaults to Ahmedabad for backwards compat) */
  citySlug?: string;
  cityName?: string;

  /* S12 CTA */
  ctaTitle: string;
  ctaSubtitle: string;
}

const {
  title, description, canonical, schemaJson,
  badge, heroH1, heroHighlight, heroDesc, heroStats, formTitle, formSub,
  s2Label = 'About the Area', s2Title, s2Subtitle, s2Body, businessTypes, overviewCards,
  s3Label = 'Our Services', s3Title, s3Subtitle, services,
  s4Label = 'Local Challenges', s4Title, s4Subtitle, challenges,
  s5Label = 'Why Choose Us', s5Title, s5Subtitle, whyCards,
  s6Label = 'Our Process', s6Title, processSteps,
  statsHeading, stats,
  s8Label = 'Client Reviews', s8Title, testimonials,
  s9Label = 'Nearby Areas', s9Title, s9Subtitle, nearbyAreas,
  s10Label = 'FAQ', s10Title, faqItems,
  otherNeighborhoods,
  citySlug = 'ahmedabad',
  cityName = 'Ahmedabad',
  ctaTitle, ctaSubtitle,
} = Astro.props;
---

<PageLayout {title} {description} {canonical}>

<script type="application/ld+json" set:html={schemaJson} slot="head"></script>

<style>
/* ── CSS Custom Properties ── */
:root {
  --nb-blue-50: #EFF6FF;
  --nb-blue-100: #DBEAFE;
  --nb-blue-200: #BFDBFE;
  --nb-blue-300: #93C5FD;
  --nb-blue-400: #60A5FA;
  --nb-blue-500: #3B82F6;
  --nb-blue-600: #2563EB;
  --nb-blue-700: #1D4ED8;
  --nb-blue-950: #0F1D35;
  --nb-gray-50: #F8FAFC;
  --nb-gray-100: #F1F5F9;
  --nb-gray-200: #E2E8F0;
  --nb-gray-400: #94A3B8;
  --nb-gray-500: #64748B;
  --nb-gray-600: #475569;
  --nb-gray-700: #334155;
  --nb-gray-800: #1E293B;
  --nb-gray-900: #0F172A;
  --nb-accent: #F59E0B;
  --nb-white: #fff;
  --nb-sp: clamp(4rem, 8vw, 7rem);
  --nb-r: 12px;
  --nb-rl: 20px;
  --nb-rf: 9999px;
  --nb-ease: cubic-bezier(0.4, 0, 0.2, 1);
}

/* ── Reset & base for this layout ── */
.nb-body {
  font-family: 'DM Sans', sans-serif;
  color: var(--nb-gray-800);
  line-height: 1.7;
}
.nb-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 clamp(1.25rem, 4vw, 2rem);
}
.nb-section-label {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--nb-blue-600);
  margin-bottom: 1rem;
}
.nb-section-label::before {
  content: '';
  width: 24px;
  height: 2px;
  background: var(--nb-blue-500);
  border-radius: 2px;
}
.nb-section-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: clamp(1.9rem, 3.5vw, 2.75rem);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -0.02em;
  color: var(--nb-gray-900);
  margin-bottom: 1rem;
}
.nb-section-title.light { color: #fff; }
.nb-section-subtitle {
  font-size: clamp(1rem, 1.4vw, 1.15rem);
  color: var(--nb-gray-500);
  max-width: 640px;
  line-height: 1.7;
}
.nb-section-subtitle.light { color: var(--nb-gray-400); }
.nb-header { margin-bottom: 3.5rem; }
.nb-header.centered { text-align: center; }
.nb-header.centered .nb-section-subtitle { margin: 0 auto; }
.nb-reveal { opacity: 0; transform: translateY(30px); transition: all 0.7s var(--nb-ease); }
.nb-reveal.nb-visible { opacity: 1; transform: translateY(0); }
.nb-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 14px 32px;
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 0.95rem;
  font-weight: 600;
  border-radius: var(--nb-rf);
  transition: all 0.3s var(--nb-ease);
  text-decoration: none;
  white-space: nowrap;
  cursor: pointer;
  border: none;
}
.nb-btn-primary { background: var(--nb-blue-600); color: #fff; box-shadow: 0 4px 14px rgba(37,99,235,.35); }
.nb-btn-primary:hover { background: var(--nb-blue-700); transform: translateY(-2px); box-shadow: 0 8px 25px rgba(37,99,235,.4); }
.nb-btn-accent { background: var(--nb-accent); color: #0a0a0a; }
.nb-btn-accent:hover { background: #D97706; transform: translateY(-2px); }
.nb-btn-outline { border: 2px solid rgba(255,255,255,.3); color: #fff; background: transparent; }
.nb-btn-outline:hover { border-color: rgba(255,255,255,.6); background: rgba(255,255,255,.08); transform: translateY(-2px); }
.nb-btn-sm { padding: 10px 24px; font-size: 0.9rem; }
.nb-breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.85rem;
  color: var(--nb-gray-500);
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}
.nb-breadcrumb a { color: var(--nb-blue-600); text-decoration: none; }
.nb-breadcrumb a:hover { text-decoration: underline; }
.nb-breadcrumb-sep { color: var(--nb-gray-400); }

/* ── S1 HERO ── */
.nb-hero {
  padding: 120px 0 clamp(3rem, 6vw, 5rem);
  background: linear-gradient(170deg, #fff 0%, var(--nb-blue-50) 50%, #fff 100%);
  position: relative;
  overflow: hidden;
}
.nb-hero::before {
  content: '';
  position: absolute;
  top: -200px;
  right: -200px;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(59,130,246,.06) 0%, transparent 70%);
  border-radius: 50%;
}
.nb-hero-grid {
  display: grid;
  grid-template-columns: 1fr 400px;
  gap: 3.5rem;
  align-items: center;
  position: relative;
  z-index: 1;
}
.nb-hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 16px;
  background: var(--nb-blue-50);
  border: 1px solid var(--nb-blue-200);
  border-radius: var(--nb-rf);
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--nb-blue-700);
  margin-bottom: 1.25rem;
}
.nb-hero h1 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: clamp(2.1rem, 4.2vw, 3.1rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.1;
  margin-bottom: 1rem;
  color: var(--nb-gray-900);
}
.nb-hero h1 .hl {
  background: linear-gradient(135deg, var(--nb-blue-600), var(--nb-blue-400));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.nb-hero-desc {
  font-size: 1.05rem;
  color: var(--nb-gray-500);
  line-height: 1.75;
  margin-bottom: 1.5rem;
  max-width: 540px;
}
.nb-hero-stats { display: flex; gap: 0; flex-wrap: wrap; }
.nb-hero-stat { padding-right: 2rem; margin-right: 2rem; border-right: 1px solid var(--nb-gray-200); }
.nb-hero-stat:last-child { padding-right: 0; margin-right: 0; border-right: none; }
.nb-hero-stat strong { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.5rem; font-weight: 800; color: var(--nb-blue-600); display: block; }
.nb-hero-stat span { font-size: 0.9rem; color: var(--nb-gray-400); }
.nb-form-card {
  background: #fff;
  border-radius: var(--nb-rl);
  padding: 2rem;
  box-shadow: 0 20px 60px rgba(0,0,0,.08), 0 1px 3px rgba(0,0,0,.05);
  border: 1px solid var(--nb-gray-100);
}
.nb-form-title { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.2rem; font-weight: 700; margin-bottom: 0.25rem; color: var(--nb-gray-900); }
.nb-form-sub { font-size: 0.9rem; color: var(--nb-gray-400); margin-bottom: 1.5rem; }
.nb-form-group { margin-bottom: 1rem; }
.nb-form-group label { display: block; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.85rem; font-weight: 600; color: var(--nb-gray-600); margin-bottom: 6px; }
.nb-form-input {
  width: 100%;
  padding: 12px 16px;
  border: 1.5px solid var(--nb-gray-200);
  border-radius: var(--nb-r);
  font-family: 'DM Sans', sans-serif;
  font-size: 0.95rem;
  color: var(--nb-gray-800);
  background: var(--nb-gray-50);
  transition: all 0.2s var(--nb-ease);
}
.nb-form-input:focus { outline: none; border-color: var(--nb-blue-500); background: #fff; box-shadow: 0 0 0 3px rgba(59,130,246,.1); }
.nb-form-input::placeholder { color: var(--nb-gray-400); }
textarea.nb-form-input { resize: vertical; min-height: 80px; }
.nb-form-submit { width: 100%; padding: 14px; margin-top: 0.5rem; display: flex; align-items: center; justify-content: center; gap: 8px; }
.nb-form-msg { margin-top: 0.75rem; padding: 0.875rem 1rem; border-radius: var(--nb-r); font-size: 0.875rem; font-weight: 500; text-align: center; }
.nb-form-msg--success { background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; }
.nb-form-msg--error { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }

/* ── S2 OVERVIEW ── */
.nb-overview {
  padding: var(--nb-sp) 0;
}
.nb-overview-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
.nb-overview-body p { font-size: 1rem; color: var(--nb-gray-600); line-height: 1.8; margin-bottom: 1.25rem; }
.nb-biz-types { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.75rem; }
.nb-biz-chip {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  background: var(--nb-blue-50);
  border: 1px solid var(--nb-blue-100);
  border-radius: var(--nb-rf);
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--nb-blue-700);
}
.nb-overview-visual {
  background: linear-gradient(135deg, var(--nb-blue-50), var(--nb-blue-100));
  border-radius: var(--nb-rl);
  padding: 2.5rem;
  display: grid;
  gap: 1.25rem;
}
.nb-ov-card {
  background: #fff;
  border-radius: var(--nb-r);
  padding: 1.5rem;
  border: 1px solid var(--nb-blue-100);
}
.nb-ov-card-icon { font-size: 1.5rem; margin-bottom: 0.75rem; }
.nb-ov-card h4 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; margin-bottom: 0.4rem; color: var(--nb-gray-900); }
.nb-ov-card p { font-size: 0.9rem; color: var(--nb-gray-500); line-height: 1.6; }

/* ── S3 SERVICES (DARK) ── */
.nb-services {
  padding: var(--nb-sp) 0;
  background: var(--nb-gray-900);
}
.nb-services .nb-section-label { color: var(--nb-blue-300); }
.nb-services .nb-section-label::before { background: var(--nb-blue-400); }
.nb-services .nb-section-subtitle.light { color: var(--nb-gray-400); }
.nb-services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
.nb-svc-card {
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: var(--nb-rl);
  padding: 2rem;
  transition: all 0.3s var(--nb-ease);
}
.nb-svc-card:hover { border-color: rgba(255,255,255,.15); background: rgba(255,255,255,.08); }
.nb-svc-icon { font-size: 1.75rem; margin-bottom: 1rem; }
.nb-svc-card h3 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.05rem; font-weight: 700; color: #fff; margin-bottom: 0.5rem; }
.nb-svc-card p { font-size: 0.9rem; color: var(--nb-gray-400); line-height: 1.7; }

/* ── S4 CHALLENGES ── */
.nb-challenges { padding: var(--nb-sp) 0; background: var(--nb-gray-50); }
.nb-challenges-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
.nb-challenge-card {
  background: #fff;
  border: 1.5px solid var(--nb-gray-100);
  border-radius: var(--nb-rl);
  padding: 2rem;
  transition: all 0.3s var(--nb-ease);
}
.nb-challenge-card:hover { border-color: var(--nb-blue-200); transform: translateY(-4px); box-shadow: 0 12px 36px rgba(0,0,0,.06); }
.nb-challenge-problem { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; color: var(--nb-gray-900); margin-bottom: 0.6rem; }
.nb-challenge-solution { font-size: 0.9rem; color: var(--nb-gray-500); line-height: 1.7; }

/* ── S5 WHY US ── */
.nb-why { padding: var(--nb-sp) 0; background: var(--nb-blue-50); }
.nb-why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
.nb-why-card {
  background: #fff;
  border-radius: var(--nb-rl);
  padding: 2.25rem;
  border: 1px solid var(--nb-blue-100);
  transition: all 0.3s var(--nb-ease);
}
.nb-why-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(0,0,0,.06); }
.nb-why-icon { width: 48px; height: 48px; border-radius: 12px; background: var(--nb-blue-100); display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem; font-size: 1.3rem; }
.nb-why-card h3 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.05rem; font-weight: 700; margin-bottom: 0.6rem; color: var(--nb-gray-900); }
.nb-why-card p { font-size: 0.9rem; color: var(--nb-gray-500); line-height: 1.7; }

/* ── S6 PROCESS (DARK) ── */
.nb-process {
  padding: var(--nb-sp) 0;
  background: linear-gradient(135deg, var(--nb-gray-900) 0%, #0F1D35 100%);
}
.nb-process .nb-section-label { color: var(--nb-blue-300); }
.nb-process .nb-section-label::before { background: var(--nb-blue-400); }
.nb-process-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; position: relative; }
.nb-process-steps::before {
  content: '';
  position: absolute;
  top: 28px;
  left: 10%;
  right: 10%;
  height: 2px;
  background: linear-gradient(90deg, var(--nb-blue-700), var(--nb-blue-500), var(--nb-blue-700));
  opacity: 0.4;
}
.nb-process-step { text-align: center; position: relative; z-index: 1; }
.nb-step-num {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--nb-blue-600), var(--nb-blue-500));
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.1rem;
  font-weight: 800;
  color: #fff;
  margin: 0 auto 1.25rem;
  box-shadow: 0 0 0 8px rgba(37,99,235,.12);
}
.nb-process-step h3 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 0.5rem; }
.nb-process-step p { font-size: 0.88rem; color: var(--nb-gray-400); line-height: 1.6; }

/* ── S7 STATS ── */
.nb-stats { padding: 4rem 0; background: var(--nb-blue-600); position: relative; overflow: hidden; }
.nb-stats::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,255,255,.06) 0%, transparent 60%); }
.nb-stats-heading { text-align: center; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 600; color: rgba(255,255,255,.7); margin-bottom: 2rem; text-transform: uppercase; letter-spacing: 0.08em; }
.nb-stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; position: relative; z-index: 1; }
.nb-stat { text-align: center; }
.nb-stat-value { font-family: 'Plus Jakarta Sans', sans-serif; font-size: clamp(2.2rem, 3.5vw, 3rem); font-weight: 800; color: #fff; line-height: 1; margin-bottom: 0.5rem; }
.nb-stat-label { font-size: 0.9rem; color: rgba(255,255,255,.75); font-weight: 500; }

/* ── S8 TESTIMONIALS ── */
.nb-testimonials { padding: var(--nb-sp) 0; }
.nb-testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
.nb-testi-card {
  background: var(--nb-gray-50);
  border: 1px solid var(--nb-gray-100);
  border-radius: var(--nb-rl);
  padding: 2rem;
  transition: all 0.3s var(--nb-ease);
}
.nb-testi-card:hover { border-color: var(--nb-blue-200); box-shadow: 0 8px 30px rgba(0,0,0,.05); }
.nb-testi-stars { display: flex; gap: 2px; color: var(--nb-accent); margin-bottom: 1rem; }
.nb-testi-text { font-size: 0.95rem; color: var(--nb-gray-600); line-height: 1.75; margin-bottom: 1.5rem; font-style: italic; }
.nb-testi-author { display: flex; align-items: center; gap: 12px; }
.nb-testi-avatar { width: 44px; height: 44px; border-radius: 50%; background: linear-gradient(135deg, var(--nb-blue-200), var(--nb-blue-400)); display: flex; align-items: center; justify-content: center; font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 0.9rem; color: #fff; flex-shrink: 0; }
.nb-testi-name { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 0.9rem; color: var(--nb-gray-900); }
.nb-testi-role { font-size: 0.85rem; color: var(--nb-gray-400); }

/* ── S9 NEARBY AREAS (DARK) ── */
.nb-nearby {
  padding: var(--nb-sp) 0;
  background: var(--nb-gray-900);
}
.nb-nearby .nb-section-label { color: var(--nb-blue-300); }
.nb-nearby .nb-section-label::before { background: var(--nb-blue-400); }
.nb-nearby-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
.nb-nearby-card {
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: var(--nb-rl);
  padding: 1.75rem;
  transition: all 0.3s var(--nb-ease);
  text-decoration: none;
  display: block;
}
.nb-nearby-card:hover { border-color: rgba(255,255,255,.15); background: rgba(255,255,255,.08); transform: translateY(-3px); }
.nb-nearby-card h3 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.05rem; font-weight: 700; color: #fff; margin-bottom: 0.5rem; }
.nb-nearby-card p { font-size: 0.9rem; color: var(--nb-gray-400); line-height: 1.6; }
.nb-nearby-card .nb-arrow { color: var(--nb-blue-400); margin-top: 1rem; font-size: 0.85rem; font-weight: 600; }

/* ── S10 FAQ ── */
.nb-faq { padding: var(--nb-sp) 0; background: var(--nb-gray-50); }
.nb-faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; max-width: 960px; margin: 0 auto; }
.nb-faq-item { border: 1.5px solid var(--nb-gray-100); border-radius: var(--nb-r); overflow: hidden; transition: all 0.3s var(--nb-ease); }
.nb-faq-item.nb-open { border-color: var(--nb-blue-200); box-shadow: 0 4px 16px rgba(37,99,235,.06); }
.nb-faq-q { width: 100%; display: flex; align-items: center; justify-content: space-between; padding: 1.25rem 1.5rem; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.95rem; font-weight: 600; color: var(--nb-gray-800); text-align: left; background: transparent; cursor: pointer; border: none; gap: 12px; }
.nb-faq-q:hover { color: var(--nb-blue-700); }
.nb-faq-icon { width: 28px; height: 28px; border-radius: 50%; background: var(--nb-blue-50); display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.3s var(--nb-ease); }
.nb-faq-item.nb-open .nb-faq-icon { background: var(--nb-blue-600); color: #fff; transform: rotate(45deg); }
.nb-faq-ans { max-height: 0; overflow: hidden; transition: max-height 0.4s var(--nb-ease); }
.nb-faq-ans-inner { padding: 0 1.5rem 1.25rem; font-size: 0.9rem; color: var(--nb-gray-500); line-height: 1.75; }

/* ── S11 INTERNAL NAV ── */
.nb-nav { padding: 3rem 0; background: var(--nb-blue-50); }
.nb-nav-inner { display: flex; flex-wrap: wrap; align-items: center; gap: 1rem; }
.nb-nav-label { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.9rem; font-weight: 700; color: var(--nb-gray-600); white-space: nowrap; }
.nb-nav-links { display: flex; flex-wrap: wrap; gap: 0.75rem; }
.nb-nav-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 18px;
  background: #fff;
  border: 1px solid var(--nb-blue-100);
  border-radius: var(--nb-rf);
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--nb-blue-700);
  text-decoration: none;
  transition: all 0.2s var(--nb-ease);
}
.nb-nav-link:hover { background: var(--nb-blue-600); color: #fff; border-color: var(--nb-blue-600); }
.nb-nav-back { margin-right: auto; }

/* ── S12 CTA ── */
.nb-cta {
  padding: var(--nb-sp) 0;
  background: linear-gradient(135deg, var(--nb-gray-900) 0%, var(--nb-blue-950) 100%);
  text-align: center;
  position: relative;
  overflow: hidden;
}
.nb-cta::before { content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: radial-gradient(ellipse at 30% 50%, rgba(59,130,246,.08) 0%, transparent 50%); }
.nb-cta-inner { position: relative; z-index: 1; }
.nb-cta h2 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: clamp(1.9rem, 3.5vw, 2.75rem); font-weight: 700; color: #fff; margin-bottom: 1rem; letter-spacing: -0.02em; }
.nb-cta p { font-size: 1.05rem; color: var(--nb-gray-400); max-width: 600px; margin: 0 auto 2.5rem; line-height: 1.7; }
.nb-cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.nb-cta-form { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1); border-radius: var(--nb-rl); padding: 2.5rem; max-width: 560px; margin: 0 auto; text-align: left; }
.nb-cta-form-title { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 1.5rem; text-align: center; }
.nb-cta-form .nb-form-input { background: rgba(255,255,255,.07); border-color: rgba(255,255,255,.15); color: #fff; }
.nb-cta-form .nb-form-input:focus { border-color: var(--nb-blue-400); background: rgba(255,255,255,.1); }
.nb-cta-form .nb-form-input::placeholder { color: rgba(255,255,255,.4); }
.nb-cta-form .nb-form-group label { color: rgba(255,255,255,.7); }

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {

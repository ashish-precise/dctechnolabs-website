m;flex-shrink:0}.author-box-name{font-family:var(--font-display);font-weight:800;font-size:1.1rem;color:var(--gray-900);margin-bottom:2px}.author-box-title{font-size:.85rem;color:var(--blue-600);font-weight:600;margin-bottom:.75rem}.author-box-bio{font-size:.9rem;color:var(--gray-600);line-height:1.7;margin:0}.post-sidebar{position:sticky;top:90px;display:flex;flex-direction:column;gap:1.5rem}.toc-card{background:#EFF6FF;border:none;border-left:4px solid var(--blue-600);border-radius:10px;padding:1.5rem 1.25rem}.toc-title{font-family:var(--font-display);font-size:1.1rem;font-weight:800;color:var(--gray-900);margin-bottom:1.25rem}.toc-nav{display:flex;flex-direction:column;max-height:380px;overflow-y:auto;scrollbar-width:thin;scrollbar-color:var(--blue-300) transparent;padding-right:4px}.toc-nav::-webkit-scrollbar{width:4px}.toc-nav::-webkit-scrollbar-track{background:transparent}.toc-nav::-webkit-scrollbar-thumb{background:var(--blue-300);border-radius:99px}:global(.toc-link){display:block;font-size:.9rem;color:var(--gray-700);padding:13px 0;border-bottom:1.5px solid #CBD5E1;text-decoration:none;line-height:1.45;transition:color .2s ease;flex-shrink:0}:global(.toc-link:last-child){border-bottom:none;padding-bottom:0}:global(.toc-link:hover){color:var(--blue-600)}:global(.toc-link.active){color:var(--blue-600);font-weight:700}:global(.toc-link.toc-h3){padding-left:1rem;font-size:.86rem;color:var(--gray-500)}.sidebar-cta{background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 100%);border-radius:var(--radius-lg);padding:1.75rem 1.5rem;text-align:center}.sidebar-cta-icon{font-size:2rem;margin-bottom:.75rem}.sidebar-cta h4{font-family:var(--font-display);font-size:1.05rem;font-weight:800;color:white;margin-bottom:.5rem}.sidebar-cta p{font-size:.875rem;color:var(--gray-400);line-height:1.65;margin-bottom:1.25rem}.related-posts-section{padding:var(--section-pad) 0;background:var(--gray-50)}.related-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}.related-card{display:block;background:white;border:1.5px solid var(--gray-100);border-radius:var(--radius-lg);overflow:hidden;text-decoration:none;color:inherit;transition:all .3s var(--ease)}.related-card:hover{transform:translateY(-4px);border-color:var(--blue-200);box-shadow:0 8px 30px rgba(37,99,235,.08)}.related-card-img{height:140px;display:flex;align-items:center;justify-content:center;position:relative}.related-emoji{font-size:2rem}.related-cat-pill{position:absolute;top:.75rem;left:.75rem;background:white;color:var(--blue-700);font-size:.7rem;font-weight:700;text-transform:uppercase;padding:3px 10px;border-radius:var(--radius-full);letter-spacing:.05em}.related-card-body{padding:1.25rem}.related-card h3{font-size:.95rem;font-weight:700;line-height:1.4;margin-bottom:.75rem;color:var(--gray-900);transition:color .2s}.related-card:hover h3{color:var(--blue-600)}.related-meta{display:flex;gap:.75rem;font-size:.8rem;color:var(--gray-500)}.post-cta-dark{padding:var(--section-pad) 0;background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 60%,#1d4ed8 100%);text-align:center}.post-cta-inner{max-width:620px;margin:0 auto}.post-cta-dark h2{font-size:clamp(1.75rem,3.5vw,2.75rem);color:white;margin:.75rem 0 1rem;letter-spacing:-.02em;line-height:1.2}.post-cta-dark p{font-size:1.05rem;color:var(--gray-400);margin-bottom:2rem;line-height:1.75}.post-cta-actions{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}.btn-outline-light{display:inline-flex;align-items:center;gap:8px;padding:14px 32px;font-family:var(--font-display);font-size:.95rem;font-weight:600;border-radius:var(--radius-full);border:2px solid rgba(255,255,255,.25);color:white;text-decoration:none;white-space:nowrap;transition:all .3s var(--ease)}.btn-outline-light:hover{border-color:rgba(255,255,255,.6);background:rgba(255,255,255,.08);transform:translateY(-2px)}.section-label.light{color:var(--blue-400);justify-content:center}.section-label.light::before{background:var(--blue-400)}

</style>


<!-- ========================================================
  FILTER JAVASCRIPT
======================================================== -->
<script>
  // ---- COUNTER ANIMATION (for StatsBar) ----
  let countersAnimated = false;

  function animateCounters() {
    if (countersAnimated) return;
    countersAnimated = true;
    document.querySelectorAll('.counter').forEach(el => {
      const target = parseInt((el as HTMLElement).dataset.target || '0', 10);
      if (isNaN(target)) return;
      const increment = target / (2000 / 16);
      let current = 0;
      const timer = setInterval(() => {
        current += increment;
        if (current >= target) {
          el.textContent = String(target);
          clearInterval(timer);
        } else {
          el.textContent = String(Math.floor(current));
        }
      }, 16);
    });
  }

  // Trigger counter when stats-bar scrolls into view
  const statsBar = document.querySelector('.stats-bar');
  if (statsBar) {
    if ('IntersectionObserver' in window) {
      const statsObserver = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            animateCounters();
            statsObserver.unobserve(e.target);
          }
        });
      }, { threshold: 0.15 });
      statsObserver.observe(statsBar);
    } else {
      animateCounters();
    }
  }

  // Blog filtering + pagination system
  const btabs          = document.querySelectorAll<HTMLButtonElement>('.blog-tab');
  const bcards         = document.querySelectorAll<HTMLElement>('.blog-card');
  const bfeatured      = document.querySelector<HTMLElement>('.blog-featured');
  const bpagination    = document.getElementById('blog-pagination') as HTMLElement | null;
  const prevBtn        = document.getElementById('page-prev') as HTMLButtonElement | null;
  const nextBtn        = document.getElementById('page-next') as HTMLButtonElement | null;
  const pageInfo       = document.getElementById('page-info') as HTMLElement | null;

  let currentFilter = 'all';
  let currentPage   = 1;

  const allPages = Array.from(bcards).reduce((max, c) => {
    return Math.max(max, parseInt((c as HTMLElement).dataset.page || '1', 10));
  }, 1);

  function applyView() {
    if (currentFilter === 'all') {
      // Show cards on current page only, hide rest
      bcards.forEach(card => {
        const cardPage = parseInt((card as HTMLElement).dataset.page || '1', 10);
        if (cardPage === currentPage) {
          card.style.display = '';
          card.style.animation = 'fadeIn 0.4s ease';
        } else {
          card.style.display = 'none';
        }
      });
      // Show pagination
      if (bpagination) bpagination.style.display = '';
      if (pageInfo)    pageInfo.textContent = `Page ${currentPage} of ${allPages}`;
      if (prevBtn)     prevBtn.disabled = currentPage <= 1;
      if (nextBtn)     nextBtn.disabled = currentPage >= allPages;
      // Show featured
      if (bfeatured) {
        const featuredSection = document.querySelector<HTMLElement>('.blog-featured-section');
        if (featuredSection) featuredSection.style.display = '';
        bfeatured.style.display = '';
      }
    } else {
      // Show all cards matching the filter regardless of page
      bcards.forEach(card => {
        const category = (card as HTMLElement).dataset.cat;
        if (category === currentFilter) {
          card.style.display = '';
          card.style.animation = 'fadeIn 0.4s ease';
        } else {
          card.style.display = 'none';
        }
      });
      // Hide pagination when filtering
      if (bpagination) bpagination.style.display = 'none';
      // Show/hide featured based on its category
      if (bfeatured) {
        const featuredCat = bfeatured.dataset.cat;
        const show = featuredCat === currentFilter;
        bfeatured.style.display = show ? '' : 'none';
        const featuredSection = document.querySelector<HTMLElement>('.blog-featured-section');
        if (featuredSection) featuredSection.style.display = show ? '' : 'none';
      }
    }
  }

  // Tab click handler
  btabs.forEach(tab => {
    tab.addEventListener('click', () => {
      currentFilter = tab.dataset.filter || 'all';
      currentPage   = 1;
      btabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      applyView();
    });
  });

  // Pagination button handlers
  if (prevBtn) {
    prevBtn.addEventListener('click', () => {
      if (currentPage > 1) { currentPage--; applyView(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
    });
  }
  if (nextBtn) {
    nextBtn.addEventListener('click', () => {
      if (currentPage < allPages) { currentPage++; applyView(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
    });
  }

  // Initialise — hide page 2 cards on load
  applyView();


  // FAQ accordion
  const faqTriggers = document.querySelectorAll<HTMLButtonElement>('.faq-trigger');

  faqTriggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item') as HTMLElement;
      const isOpen = item.classList.contains('open');

      // Close all
      document.querySelectorAll('.faq-item').forEach(el => el.classList.remove('open'));
      faqTriggers.forEach(t => t.setAttribute('aria-expanded', 'false'));

      // Open clicked (unless it was already open)
      if (!isOpen) {
        item.classList.add('open');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

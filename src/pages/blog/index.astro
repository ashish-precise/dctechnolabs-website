---
// src/pages/blog/index.astro
// DC technolabs v2, Blog Listing Page
// 10 sections: Hero, Filters, Featured Post, Blog Grid, Newsletter,
//               Topics, Stats Bar, CTA Dark, FAQ, Final CTA

import PageLayout from '../../layouts/PageLayout.astro';
import StatsBar from '../../components/StatsBar.astro';
import CtaBanner from '../../components/CtaBanner.astro';
---

<PageLayout
  title="Blog | Digital Marketing Tips & Insights | DC technolabs"
  description="Expert tips on web design, SEO, PPC, social media, and e-commerce from DC technolabs Ahmedabad. Actionable guides for Gujarat businesses."
  canonical="https://dctechnolabs.in/blog/"
>

<!-- ========================================================
  SECTION 1: HERO (LEFT-ALIGNED, no stats)
======================================================== -->
<section class="blog-hero">
  <div class="container">
    <span class="section-label">Blog</span>
    <h1>Insights That <span class="highlight">Actually Help.</span></h1>
    <p class="blog-hero-desc">
      Practical digital marketing advice for businesses in Ahmedabad and beyond.
      Real strategies that work, written by the team that implements them every day.
    </p>
  </div>
</section>


<!-- ========================================================
  SECTION 2: FILTER TABS (centered, NOT sticky)
======================================================== -->
<section class="blog-filters-section">
  <div class="container">
    <div class="blog-filters">
      <button class="blog-tab active" data-filter="all">All Posts</button>
      <button class="blog-tab" data-filter="seo">SEO</button>
      <button class="blog-tab" data-filter="web-design">Web Design</button>
      <button class="blog-tab" data-filter="ppc">PPC</button>
      <button class="blog-tab" data-filter="ecommerce">E-commerce</button>
      <button class="blog-tab" data-filter="social">Social Media</button>
      <button class="blog-tab" data-filter="marketing">Marketing</button>
    </div>
  </div>
</section>


<!-- ========================================================
  SECTION 3: FEATURED POST (2-column: image left, content right)
======================================================== -->
<section class="blog-featured-section">
  <div class="container">
    <a
      href="/blog/google-business-profile-setup-ahmedabad"
      class="blog-featured"
      data-cat="seo"
    >
      <div
        class="featured-image"
        style="background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 100%);"
      >
        <span class="featured-badge">Latest Post</span>
        <span class="blog-emoji">📍</span>
      </div>

      <div class="featured-content">
        <span class="featured-cat">SEO</span>
        <h2>How to Set Up and Optimise Your Google Business Profile in Ahmedabad</h2>
        <p>
          Your Google Business Profile is often the first thing local customers see. Here is a step-by-step guide to setting it up correctly and getting more calls and walk-ins.
        </p>
        <div class="featured-meta">
          <span>📅 Mar 5, 2026</span>
          <span>⏱️ 10 min read</span>
        </div>
        <span class="btn btn-primary">Read Article →</span>
      </div>
    </a>
  </div>
</section>


<!-- ========================================================
  SECTION 4: BLOG GRID (14 cards, 3-column, sorted newest first)
======================================================== -->
<section class="blog-grid-section">
  <div class="container">
    <div class="blog-grid" id="blog-grid">

      <!-- Page 1 cards (data-page="1") -->

      <!-- Card 1: Social Media — Mar 5, 2026 -->
      <a href="/blog/whatsapp-business-marketing-guide-india" class="blog-card" data-cat="social" data-page="1">
        <div class="blog-card-image" style="background: linear-gradient(135deg, #065f46 0%, #25d366 100%);">
          <span class="blog-emoji">💬</span>
          <span class="blog-cat-pill">Social Media</span>
        </div>
        <div class="blog-card-body">
          <h3>WhatsApp Business Marketing Guide for Indian Businesses</h3>
          <p class="blog-desc">How to use WhatsApp Business to generate leads, nurture customers, and close sales without paid ads.</p>
          <div class="blog-meta">
            <span>📅 Mar 5, 2026</span>
            <span>⏱️ 9 min</span>
          </div>
        </div>
      </a>

      <!-- Card 2: Marketing — Mar 5, 2026 -->
      <a href="/blog/how-to-choose-digital-marketing-agency-ahmedabad" class="blog-card" data-cat="marketing" data-page="1">
        <div class="blog-card-image" style="background: linear-gradient(135deg, #1e3a5f 0%, #6366f1 100%);">
          <span class="blog-emoji">🤝</span>
          <span class="blog-cat-pill">Marketing</span>
        </div>
        <div class="blog-card-body">
          <h3>How to Choose a Digital Marketing Agency in Ahmedabad</h3>
          <p class="blog-desc">Seven questions to ask before signing a contract, plus the red flags that reveal agencies to avoid.</p>
          <div class="blog-meta">
            <span>📅 Mar 5, 2026</span>
            <span>⏱️ 8 min</span>
          </div>
        </div>
      </a>

      <!-- Card 3: E-commerce — Mar 5, 2026 -->
      <a href="/blog/ecommerce-for-indian-businesses-2026" class="blog-card" data-cat="ecommerce" data-page="1">
        <div class="blog-card-image" style="background: linear-gradient(135deg, #064e3b 0%, #10b981 100%);">
          <span class="blog-emoji">🛍️</span>
          <span class="blog-cat-pill">E-commerce</span>
        </div>
        <div class="blog-card-body">
          <h3>Starting an E-commerce Business in India: The 2026 Guide</h3>
          <p class="blog-desc">Platform choices, payment gateways, shipping partners, GST, and everything else you need to sell online in India.</p>
          <div class="blog-meta">
            <span>📅 Mar 5, 2026</span>
            <span>⏱️ 11 min</span>
          </div>
        </div>
      </a>

      <!-- Card 4: Web Design — Mar 4, 2025 -->
      <a href="/blog/how-to-choose-web-design-company-ahmedabad" class="blog-card" data-cat="web-design" data-page="1">
        <div class="blog-card-image" style="background: linear-gradient(135deg, #1e3a5f 0%, #0ea5e9 100%);">
          <span class="blog-emoji">🏢</span>
          <span class="blog-cat-pill">Web Design</span>
        </div>
        <div class="blog-card-body">
          <h3>How to Choose a Web Design Company in Ahmedabad: 10 Questions to Ask</h3>
          <p class="blog-desc">Before hiring a web design agency in Ahmedabad, ask these 10 questions. They reveal everything about quality, process, and trustworthiness.</p>
          <div class="blog-meta">
            <span>📅 Mar 4, 2025</span>
            <span>⏱️ 9 min</span>
          </div>
        </div>
      </a>

      <!-- Card 5: SEO — Feb 20, 2025 -->
      <a href="/blog/seo-mistakes-ahmedabad-businesses-2025" class="blog-card" data-cat="seo" data-page="1">
        <div class="blog-card-image" style="background: linear-gradient(135deg, #1e293b 0%, #0d9488 100%);">
          <span class="blog-emoji">🔍</span>
          <span class="blog-cat-pill">SEO</span>
        </div>
        <div class="blog-card-body">
          <h3>10 SEO Mistakes Ahmedabad Businesses Still Make in 2025</h3>
          <p class="blog-desc">Most local businesses lose rankings because of these common errors. Here is how to fix each one and start climbing Google.</p>
          <div class="blog-meta">
            <span>📅 Feb 20, 2025</span>
            <span>⏱️ 8 min</span>
          </div>
        </div>
      </a>

      <!-- Card 6: Web Design — Feb 15, 2025 -->
      <a href="/blog/website-cost-india-2025" class="blog-card" data-cat="web-design" data-page="1">
        <div class="blog-card-image" style="background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%);">
          <span class="blog-emoji">🎨</span>
          <span class="blog-cat-pill">Web Design</span>
        </div>
        <div class="blog-card-body">
          <h3>How Much Does a Website Cost in India? 2025 Guide</h3>
          <p class="blog-desc">Complete breakdown of website development costs in India, from basic landing pages to complex e-commerce platforms.</p>
          <div class="blog-meta">
            <span>📅 Feb 15, 2025</span>
            <span>⏱️ 12 min</span>
          </div>
        </div>
      </a>

      <!-- Card 7: PPC — Feb 10, 2025 -->
      <a href="/blog/google-ads-vs-facebook-ads-gujarat" class="blog-card" data-cat="ppc" data-page="1">
        <div class="blog-card-image" style="background: linear-gradient(135deg, #312e81 0%, #7c3aed 100%);">
          <span class="blog-emoji">📊</span>
          <span class="blog-cat-pill">PPC</span>
        </div>
        <div class="blog-card-body">
          <h3>Google Ads vs Facebook Ads: Which Works Better for Gujarat Businesses?</h3>
          <p class="blog-desc">Data-backed comparison of both platforms for local businesses, with real ROI numbers from Gujarat campaigns.</p>
          <div class="blog-meta">
            <span>📅 Feb 10, 2025</span>
            <span>⏱️ 10 min</span>
          </div>
        </div>
      </a>

      <!-- Card 8: Web Design — Feb 5, 2025 -->
      <a href="/blog/website-cost-ahmedabad-2025" class="blog-card" data-cat="web-design" data-page="1">
        <div class="blog-card-image" style="background: linear-gradient(135deg, #0c4a6e 0%, #0ea5e9 100%);">
          <span class="blog-emoji">💻</span>
          <span class="blog-cat-pill">Web Design</span>
        </div>
        <div class="blog-card-body">
          <h3>How Much Does a Website Cost in Ahmedabad? 2025 Pricing Guide</h3>
          <p class="blog-desc">Local pricing breakdown for websites in Ahmedabad, what agencies actually charge, and how to get the best value.</p>
          <div class="blog-meta">
            <span>📅 Feb 5, 2025</span>
            <span>⏱️ 10 min</span>
          </div>
        </div>
      </a>

      <!-- Card 9: E-commerce — Feb 5, 2025 -->
      <a href="/blog/shopify-vs-woocommerce-2025" class="blog-card" data-cat="ecommerce" data-page="1">
        <div class="blog-card-image" style="background: linear-gradient(135deg, #065f46 0%, #059669 100%);">
          <span class="blog-emoji">🛒</span>
          <span class="blog-cat-pill">E-commerce</span>
        </div>
        <div class="blog-card-body">
          <h3>Shopify vs WooCommerce: Which Platform Is Right for Your Store?</h3>
          <p class="blog-desc">Detailed comparison covering pricing, features, ease of use, and which platform suits Indian businesses better.</p>
          <div class="blog-meta">
            <span>📅 Feb 5, 2025</span>
            <span>⏱️ 9 min</span>
          </div>
        </div>
      </a>

      <!-- Page 2 cards (data-page="2") -->

      <!-- Card 10: Social Media — Jan 28, 2025 -->
      <a href="/blog/instagram-reels-strategy-2025" class="blog-card" data-cat="social" data-page="2">
        <div class="blog-card-image" style="background: linear-gradient(135deg, #831843 0%, #ec4899 100%);">
          <span class="blog-emoji">📱</span>
          <span class="blog-cat-pill">Social Media</span>
        </div>
        <div class="blog-card-body">
          <h3>Instagram Reels Strategy for Small Businesses in 2025</h3>
          <p class="blog-desc">Step-by-step guide to creating Reels that actually drive traffic and sales for local Gujarat businesses.</p>
          <div class="blog-meta">
            <span>📅 Jan 28, 2025</span>
            <span>⏱️ 7 min</span>
          </div>
        </div>
      </a>

      <!-- Card 11: Web Design — Jan 22, 2025 -->
      <a href="/blog/fix-slow-website-loading" class="blog-card" data-cat="web-design" data-page="2">
        <div class="blog-card-image" style="background: linear-gradient(135deg, #7c2d12 0%, #ea580c 100%);">
          <span class="blog-emoji">🔧</span>
          <span class="blog-cat-pill">Web Design</span>
        </div>
        <div class="blog-card-body">
          <h3>Why Your Website Loads Slowly (And How to Fix It Today)</h3>
          <p class="blog-desc">Common causes of slow websites and practical fixes you can implement today to improve loading speed and Core Web Vitals.</p>
          <div class="blog-meta">
            <span>📅 Jan 22, 2025</span>
            <span>⏱️ 6 min</span>
          </div>
        </div>
      </a>

      <!-- Card 12: SEO — Jan 15, 2025 -->
      <a href="/blog/local-seo-checklist-ahmedabad" class="blog-card" data-cat="seo" data-page="2">
        <div class="blog-card-image" style="background: linear-gradient(135deg, #0f172a 0%, #3b82f6 100%);">
          <span class="blog-emoji">📈</span>
          <span class="blog-cat-pill">SEO</span>
        </div>
        <div class="blog-card-body">
          <h3>Local SEO Checklist: How to Rank #1 in Ahmedabad</h3>
          <p class="blog-desc">Complete checklist for dominating local search results in Ahmedabad, from Google My Business to local link building.</p>
          <div class="blog-meta">
            <span>📅 Jan 15, 2025</span>
            <span>⏱️ 11 min</span>
          </div>
        </div>
      </a>

      <!-- Card 13: PPC — Jan 10, 2025 -->
      <a href="/blog/reduce-google-ads-cost-per-lead" class="blog-card" data-cat="ppc" data-page="2">
        <div class="blog-card-image" style="background: linear-gradient(135deg, #4a1d96 0%, #8b5cf6 100%);">
          <span class="blog-emoji">💰</span>
          <span class="blog-cat-pill">PPC</span>
        </div>
        <div class="blog-card-body">
          <h3>How to Reduce Google Ads Cost Per Lead by 40%</h3>
          <p class="blog-desc">Proven strategies to cut your Google Ads costs while maintaining or improving lead quality and conversion rates.</p>
          <div class="blog-meta">
            <span>📅 Jan 10, 2025</span>
            <span>⏱️ 8 min</span>
          </div>
        </div>
      </a>

      <!-- Card 14: E-commerce — Jan 5, 2025 -->
      <a href="/blog/razorpay-shopify-setup-guide" class="blog-card" data-cat="ecommerce" data-page="2">
        <div class="blog-card-image" style="background: linear-gradient(135deg, #065f46 0%, #10b981 100%);">
          <span class="blog-emoji">🏪</span>
          <span class="blog-cat-pill">E-commerce</span>
        </div>
        <div class="blog-card-body">
          <h3>Setting Up Razorpay on Your Shopify Store: Complete Guide</h3>
          <p class="blog-desc">Step-by-step tutorial for integrating Razorpay payment gateway on Shopify for Indian e-commerce stores.</p>
          <div class="blog-meta">
            <span>📅 Jan 5, 2025</span>
            <span>⏱️ 7 min</span>
          </div>
        </div>
      </a>

    </div>

    <!-- Pagination Controls -->
    <div class="blog-pagination" id="blog-pagination">
      <button class="page-btn page-prev" id="page-prev" disabled>← Previous</button>
      <span class="page-info" id="page-info">Page 1 of 2</span>
      <button class="page-btn page-next" id="page-next">Next →</button>
    </div>

  </div>
</section>


<!-- ========================================================
  SECTION 5: STATS BAR (moved here, breaks white sections,
  dark CTA later stays visually distinct)
======================================================== -->
<StatsBar />


<!-- ========================================================
  SECTION 6: NEWSLETTER SIGNUP
======================================================== -->
<section class="newsletter-section">
  <div class="container">
    <div class="section-header centered">
      <span class="section-label">Stay Updated</span>
      <h2 class="section-title">Get Digital Marketing Tips in Your Inbox</h2>
      <p class="section-subtitle">
        One email per week with actionable tips, case studies, and industry
        updates. No spam, unsubscribe anytime.
      </p>
    </div>

    <form
      class="newsletter-form"
      onsubmit="event.preventDefault(); alert('Newsletter signup coming soon!');"
    >
      <input
        type="email"
        class="newsletter-input"
        placeholder="Enter your email address"
        required
      />
      <button type="submit" class="btn btn-primary">Subscribe</button>
    </form>
  </div>
</section>


<!-- ========================================================
  SECTION 6: TOPICS WE COVER
======================================================== -->
<section class="topics-section">
  <div class="container">
    <div class="section-header centered">
      <span class="section-label">Topics We Cover</span>
      <h2 class="section-title">Explore by Category</h2>
    </div>

    <div class="topics-grid">
      <a href="/blog?cat=seo" class="topic-card">
        <div class="topic-icon">🔍</div>
        <h3>SEO</h3>
        <p>Rankings, keywords, local SEO</p>
      </a>

      <a href="/blog?cat=web-design" class="topic-card">
        <div class="topic-icon">🎨</div>
        <h3>Web Design</h3>
        <p>Design, UX, speed, conversions</p>
      </a>

      <a href="/blog?cat=ppc" class="topic-card">
        <div class="topic-icon">📊</div>
        <h3>PPC / Google Ads</h3>
        <p>Ad strategy, ROAS, campaigns</p>
      </a>

      <a href="/blog?cat=ecommerce" class="topic-card">
        <div class="topic-icon">🛒</div>
        <h3>E-commerce</h3>
        <p>Shopify, WooCommerce, payments</p>
      </a>

      <a href="/blog?cat=social" class="topic-card">
        <div class="topic-icon">📱</div>
        <h3>Social Media</h3>
        <p>Instagram, Facebook, content</p>
      </a>

      <a href="/blog?cat=business" class="topic-card">
        <div class="topic-icon">💼</div>
        <h3>Business Growth</h3>
        <p>Strategy, scaling, operations</p>
      </a>

      <a href="/blog?cat=tools" class="topic-card">
        <div class="topic-icon">🔧</div>
        <h3>Tools &amp; Tech</h3>
        <p>Analytics, platforms, tutorials</p>
      </a>

      <a href="/blog?cat=case-studies" class="topic-card">
        <div class="topic-icon">📈</div>
        <h3>Case Studies</h3>
        <p>Real results, client stories</p>
      </a>
    </div>
  </div>
</section>


<!-- ========================================================
  SECTION 8: CTA DARK
======================================================== -->
<section class="cta-dark">
  <div class="container">
    <div class="cta-dark-inner">
      <div class="cta-dark-label-wrap">
        <span class="section-label light">Need Expert Help?</span>
      </div>
      <h2>Reading Is Good. Results Are Better.</h2>
      <p>Our blog gives you the knowledge. Our team gives you the execution.</p>
      <div class="cta-dark-actions">
        <a href="/contact" class="btn btn-accent">Get a Free Consultation</a>
        <a href="/portfolio" class="btn btn-outline-light">See Our Work →</a>
      </div>
    </div>
  </div>
</section>


<!-- ========================================================
  SECTION 9: FAQ
======================================================== -->
<section class="blog-faq-section">
  <div class="container">
    <div class="section-header centered">
      <span class="section-label">Blog Questions</span>
      <h2 class="section-title">About Our Blog</h2>
    </div>

    <div class="faq-grid">

      <div class="faq-item">
        <button class="faq-trigger" aria-expanded="false">
          <span>How often do you publish new articles?</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="faq-body">
          <p>We publish new articles every week, usually on Tuesdays. Our team covers a mix of SEO, web design, PPC, e-commerce, and social media topics to keep your digital marketing knowledge fresh and relevant.</p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-trigger" aria-expanded="false">
          <span>Can I suggest a topic for the blog?</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="faq-body">
          <p>Absolutely. We love hearing from readers. If you have a topic you'd like us to cover, send us a message through the contact page. We prioritize topics that our audience asks for most frequently.</p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-trigger" aria-expanded="false">
          <span>Are these strategies specific to Gujarat businesses?</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="faq-body">
          <p>Many of our articles have a local Ahmedabad or Gujarat focus, but the strategies themselves apply to businesses across India. We draw examples from local markets because that's where we have the most first-hand data.</p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-trigger" aria-expanded="false">
          <span>Can I republish your articles on my website?</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="faq-body">
          <p>Our content is original and copyrighted. You're welcome to quote short excerpts with a link back to the original article, but full republishing requires written permission from our team. Contact us to discuss syndication options.</p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-trigger" aria-expanded="false">
          <span>Do you offer guest posting opportunities?</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="faq-body">
          <p>We selectively accept guest contributions from established digital marketing professionals. Articles must be original, practical, and relevant to our audience. Reach out with your topic idea and writing samples for consideration.</p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-trigger" aria-expanded="false">
          <span>Will implementing these tips guarantee results?</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="faq-body">
          <p>No strategy guarantees results because every business, market, and competitive landscape is different. Our tips are based on real campaigns we've run, but results will vary. For guaranteed execution with accountability, consider working with our team directly.</p>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ========================================================
  SECTION 10: FINAL CTA (reuse CtaBanner component)
======================================================== -->
<CtaBanner
  title="Ready to Grow Your Business Online?"
  subtitle="Stop reading about digital marketing and start seeing results. Get a free strategy consultation within 24 hours."
  ctaLabel="Get Your Free Quote"
  ctaHref="/contact"
/>


</PageLayout>


<!-- ========================================================
  PAGE STYLES
======================================================== -->
<style>

/* ---- SECTION 1: HERO ---- */
.blog-hero {
  padding: 120px 0 clamp(3rem, 6vw, 5rem);
  background: linear-gradient(170deg, var(--white) 0%, var(--blue-50) 50%, var(--white) 100%);
  position: relative;
  overflow: hidden;
}

.blog-hero::before {
  content: '';
  position: absolute;
  top: -200px;
  right: -200px;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(59, 130, 246, 0.06) 0%, transparent 70%);
  border-radius: 50%;
}

.blog-hero .container {
  position: relative;
  z-index: 1;
}

.blog-hero h1 {
  font-size: clamp(2.5rem, 5vw, 3.75rem);
  letter-spacing: -0.03em;
  line-height: 1.1;
  margin-bottom: 1.25rem;
  animation: fadeInUp 0.6s var(--ease) 0.1s both;
}

.blog-hero h1 .highlight {
  background: linear-gradient(135deg, var(--blue-600), var(--blue-400));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.blog-hero .section-label {
  animation: fadeInUp 0.6s var(--ease) both;
}

.blog-hero-desc {
  font-size: clamp(1.05rem, 1.5vw, 1.2rem);
  color: var(--gray-500);
  line-height: 1.75;
  max-width: 580px;
  animation: fadeInUp 0.6s var(--ease) 0.2s both;
}


/* ---- SECTION 2: FILTER TABS ---- */

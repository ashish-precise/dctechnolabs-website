r:var(--gray-500)}.post-date{display:flex;align-items:center;gap:6px;font-size:.875rem;color:var(--gray-500)}.share-row{display:flex;align-items:center;gap:.75rem;flex-wrap:wrap}.share-label{font-family:var(--font-display);font-size:.875rem;font-weight:600;color:var(--gray-600)}.share-buttons{display:flex;gap:.5rem;flex-wrap:wrap}.share-btn{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:var(--radius-full);border:1.5px solid var(--gray-200);font-family:var(--font-display);font-size:.8rem;font-weight:600;color:var(--gray-700);text-decoration:none;transition:all .2s var(--ease);white-space:nowrap}.share-btn:hover{transform:translateY(-1px)}.share-whatsapp:hover{background:#25D366;border-color:#25D366;color:white}.share-linkedin:hover{background:#0A66C2;border-color:#0A66C2;color:white}.share-x:hover{background:#000;border-color:#000;color:white}.share-facebook:hover{background:#1877F2;border-color:#1877F2;color:white}.post-body{padding:4rem 0 5rem;background:white}.post-layout{display:grid;grid-template-columns:1fr 300px;gap:4rem;align-items:start}.post-article{min-width:0}.post-article .lead{font-size:1.125rem;color:var(--gray-700);line-height:1.8;margin-bottom:1.5rem;font-style:italic;border-left:3px solid var(--blue-500);padding-left:1.25rem}.post-article p{font-size:1rem;color:var(--gray-700);line-height:1.85;margin-bottom:1.25rem}.post-article h2{font-size:1.625rem;font-weight:800;color:var(--blue-800);margin:2.75rem 0 1rem;letter-spacing:-.025em;line-height:1.25;scroll-margin-top:96px}.post-article h3{font-size:1.2rem;font-weight:700;color:var(--blue-600);margin:1.75rem 0 .75rem;line-height:1.35;scroll-margin-top:96px}.post-article ul,.post-article ol{padding-left:1.5rem;margin-bottom:1.25rem}.post-article li{color:var(--gray-700);font-size:1rem;line-height:1.8;margin-bottom:.5rem}.post-article strong{color:var(--gray-900);font-weight:700}.mid-cta{background:linear-gradient(135deg,var(--blue-600) 0%,var(--blue-800) 100%);border-radius:var(--radius-lg);padding:2.25rem 2.5rem;margin:2.75rem 0}.mid-cta-tag{display:inline-block;background:rgba(255,255,255,.18);color:white;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;padding:4px 12px;border-radius:var(--radius-full);margin-bottom:.75rem}.mid-cta h3{font-size:1.375rem;font-weight:800;color:white;margin:.5rem 0 .75rem;line-height:1.3}.mid-cta p{font-size:.95rem;color:rgba(255,255,255,.85);line-height:1.7;margin-bottom:1.5rem}.btn-white{display:inline-flex;align-items:center;gap:8px;padding:12px 28px;background:white;color:var(--blue-700);font-family:var(--font-display);font-size:.9rem;font-weight:700;border-radius:var(--radius-full);text-decoration:none;transition:all .3s var(--ease)}.btn-white:hover{background:var(--blue-50);transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,.15)}.btn-sm{padding:10px 22px;font-size:.875rem}.post-tags{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin:2.5rem 0 1.5rem;padding-top:2rem;border-top:1px solid var(--gray-100)}.tag-label{font-family:var(--font-display);font-size:.875rem;font-weight:600;color:var(--gray-500)}.tag-pill{display:inline-block;background:var(--blue-50);color:var(--blue-700);border:1px solid var(--blue-100);font-size:.8rem;font-weight:600;padding:4px 12px;border-radius:var(--radius-full);text-decoration:none;transition:all .2s}.tag-pill:hover{background:var(--blue-600);color:white;border-color:var(--blue-600)}.share-bottom{padding:1.5rem 0;border-top:1px solid var(--gray-100);border-bottom:1px solid var(--gray-100);margin-bottom:2.5rem}.author-box{display:flex;gap:1.5rem;background:var(--blue-50);border:1.5px solid var(--blue-100);border-radius:var(--radius-lg);padding:2rem;margin-top:1rem}.author-box-avatar{width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--blue-600),var(--blue-800));color:white;display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:800;font-size:1.5rem;flex-shrink:0}.author-box-name{font-family:var(--font-display);font-weight:800;font-size:1.1rem;color:var(--gray-900);margin-bottom:2px}.author-box-title{font-size:.85rem;color:var(--blue-600);font-weight:600;margin-bottom:.75rem}.author-box-bio{font-size:.9rem;color:var(--gray-600);line-height:1.7;margin:0}.post-sidebar{position:sticky;top:90px;display:flex;flex-direction:column;gap:1.5rem}.toc-card{background:#EFF6FF;border:none;border-left:4px solid var(--blue-600);border-radius:10px;padding:1.5rem 1.25rem}.toc-title{font-family:var(--font-display);font-size:1.1rem;font-weight:800;color:var(--gray-900);margin-bottom:1.25rem}.toc-nav{display:flex;flex-direction:column;max-height:380px;overflow-y:auto;scrollbar-width:thin;scrollbar-color:var(--blue-300) transparent;padding-right:4px}.toc-nav::-webkit-scrollbar{width:4px}.toc-nav::-webkit-scrollbar-track{background:transparent}.toc-nav::-webkit-scrollbar-thumb{background:var(--blue-300);border-radius:99px}:global(.toc-link){display:block;font-size:.9rem;color:var(--gray-700);padding:13px 0;border-bottom:1.5px solid #CBD5E1;text-decoration:none;line-height:1.45;transition:color .2s ease;flex-shrink:0}:global(.toc-link:last-child){border-bottom:none;padding-bottom:0}:global(.toc-link:hover){color:var(--blue-600)}:global(.toc-link.active){color:var(--blue-600);font-weight:700}:global(.toc-link.toc-h3){padding-left:1rem;font-size:.86rem;color:var(--gray-500)}.sidebar-cta{background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 100%);border-radius:var(--radius-lg);padding:1.75rem 1.5rem;text-align:center}.sidebar-cta-icon{font-size:2rem;margin-bottom:.75rem}.sidebar-cta h4{font-family:var(--font-display);font-size:1.05rem;font-weight:800;color:white;margin-bottom:.5rem}.sidebar-cta p{font-size:.875rem;color:var(--gray-400);line-height:1.65;margin-bottom:1.25rem}.related-posts-section{padding:var(--section-pad) 0;background:var(--gray-50)}.related-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}.related-card{display:block;background:white;border:1.5px solid var(--gray-100);border-radius:var(--radius-lg);overflow:hidden;text-decoration:none;color:inherit;transition:all .3s var(--ease)}.related-card:hover{transform:translateY(-4px);border-color:var(--blue-200);box-shadow:0 8px 30px rgba(37,99,235,.08)}.related-card-img{height:140px;display:flex;align-items:center;justify-content:center;position:relative}.related-emoji{font-size:2rem}.related-cat-pill{position:absolute;top:.75rem;left:.75rem;background:white;color:var(--blue-700);font-size:.7rem;font-weight:700;text-transform:uppercase;padding:3px 10px;border-radius:var(--radius-full);letter-spacing:.05em}.related-card-body{padding:1.25rem}.related-card h3{font-size:.95rem;font-weight:700;line-height:1.4;margin-bottom:.75rem;color:var(--gray-900);transition:color .2s}.related-card:hover h3{color:var(--blue-600)}.related-meta{display:flex;gap:.75rem;font-size:.8rem;color:var(--gray-500)}.post-cta-dark{padding:var(--section-pad) 0;background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 60%,#1d4ed8 100%);text-align:center}.post-cta-inner{max-width:620px;margin:0 auto}.post-cta-dark h2{font-size:clamp(1.75rem,3.5vw,2.75rem);color:white;margin:.75rem 0 1rem;letter-spacing:-.02em;line-height:1.2}.post-cta-dark p{font-size:1.05rem;color:var(--gray-400);margin-bottom:2rem;line-height:1.75}.post-cta-actions{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}.btn-outline-light{display:inline-flex;align-items:center;gap:8px;padding:14px 32px;font-family:var(--font-display);font-size:.95rem;font-weight:600;border-radius:var(--radius-full);border:2px solid rgba(255,255,255,.25);color:white;text-decoration:none;white-space:nowrap;transition:all .3s var(--ease)}.btn-outline-light:hover{border-color:rgba(255,255,255,.6);background:rgba(255,255,255,.08);transform:translateY(-2px)}.section-label.light{color:var(--blue-400);justify-content:center}.section-label.light::before{background:var(--blue-400)}
@media(max-width:1024px){.post-layout{grid-template-columns:1fr;gap:0}.post-sidebar{position:static;order:-1;margin-bottom:2.5rem}.toc-card{display:none}.related-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:768px){.post-header{padding:100px 0 2.5rem}.post-layout{grid-template-columns:1fr}.related-grid{grid-template-columns:1fr}.author-box{flex-direction:column;gap:1rem}.post-cta-actions{flex-direction:column;align-items:center}.share-btn{padding:5px 10px;font-size:.75rem}.mid-cta{padding:1.5rem 1.25rem}}
</style>

<script>
  const article = document.getElementById('post-article') as HTMLElement | null;
  const tocNav  = document.getElementById('toc-nav') as HTMLElement | null;
  if (article && tocNav) {
    const headings = article.querySelectorAll<HTMLHeadingElement>('h2, h3');
    headings.forEach((heading, index) => {
      if (!heading.id) { heading.id = (heading.textContent || '').toLowerCase().replace(/[^a-z0-9\s]/g, '').replace(/\s+/g, '-').slice(0, 60) || `heading-${index}`; }
      const link = document.createElement('a');
      link.href = `#${heading.id}`; link.textContent = heading.textContent || '';
      link.className = heading.tagName === 'H3' ? 'toc-link toc-h3' : 'toc-link';
      link.addEventListener('click', (e) => { e.preventDefault(); const target = document.getElementById(heading.id); if (target) { const top = target.getBoundingClientRect().top + window.scrollY - 96; window.scrollTo({ top, behavior: 'smooth' }); } });
      tocNav.appendChild(link);
    });
    const tocLinks = tocNav.querySelectorAll<HTMLAnchorElement>('.toc-link');
    const headingArray = Array.from(headings) as HTMLHeadingElement[];
    function updateActiveToc() {
      let activeId = headingArray.length > 0 ? headingArray[0].id : '';
      for (let i = headingArray.length - 1; i >= 0; i--) { if (headingArray[i].getBoundingClientRect().top <= 110) { activeId = headingArray[i].id; break; } }
      tocLinks.forEach(l => { l.classList.toggle('active', l.getAttribute('href') === `#${activeId}`); });
    }
    window.addEventListener('scroll', updateActiveToc, { passive: true });
    updateActiveToc();
  }
  const pageUrl = encodeURIComponent(window.location.href);
  const pageTitle = encodeURIComponent(document.title);
  const shareMap: Record<string, string> = { 'share-whatsapp': `https://wa.me/?text=${pageTitle}%20${pageUrl}`, 'share-linkedin': `https://www.linkedin.com/sharing/share-offsite/?url=${pageUrl}`, 'share-x': `https://twitter.com/intent/tweet?text=${pageTitle}&url=${pageUrl}`, 'share-facebook': `https://www.facebook.com/sharer/sharer.php?u=${pageUrl}` };
  ['share-top', 'share-bottom'].forEach(groupId => { const group = document.getElementById(groupId); if (!group) return; Object.entries(shareMap).forEach(([cls, url]) => { const btn = group.querySelector<HTMLAnchorElement>(`.${cls}`); if (btn) btn.href = url; }); });
</script>

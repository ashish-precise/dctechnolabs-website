.post-cta-dark p { font-size: 1.05rem; color: var(--gray-400); margin-bottom: 2rem; line-height: 1.75; }
.post-cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.btn-outline-light { display: inline-flex; align-items: center; gap: 8px; padding: 14px 32px; font-family: var(--font-display); font-size: .95rem; font-weight: 600; border-radius: var(--radius-full); border: 2px solid rgba(255,255,255,.25); color: white; text-decoration: none; white-space: nowrap; transition: all .3s var(--ease); }
.btn-outline-light:hover { border-color: rgba(255,255,255,.6); background: rgba(255,255,255,.08); transform: translateY(-2px); }

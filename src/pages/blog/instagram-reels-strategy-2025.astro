.related-card:hover { transform: translateY(-4px); border-color: var(--blue-200); box-shadow: 0 8px 30px rgba(37,99,235,.08); }
.related-card-img { height: 140px; display: flex; align-items: center; justify-content: center; position: relative; }
.related-emoji { font-size: 2rem; }
.related-cat-pill { position: absolute; top: .75rem; left: .75rem; background: white; color: var(--blue-700); font-size: .7rem; font-weight: 700; text-transform: uppercase; padding: 3px 10px; border-radius: var(--radius-full); letter-spacing: .05em; }
.related-card-body { padding: 1.25rem; }
.related-card h3 { font-size: .95rem; font-weight: 700; line-height: 1.4; margin-bottom: .75rem; color: var(--gray-900); transition: color .2s; }
.related-card:hover h3 { color: var(--blue-600); }
.related-meta { display: flex; gap: .75rem; font-size: .8rem; color: var(--gray-500); }
.post-cta-dark { padding: var(--section-pad) 0; background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1d4ed8 100%); text-align: center; }
.post-cta-inner { max-width: 620px; margin: 0 auto; }
.post-cta-dark h2 { font-size: clamp(1.75rem, 3.5vw, 2.75rem); color: white; margin: .75rem 0 1rem; letter-spacing: -.02em; line-height: 1.2; }
.post-cta-dark p { font-size: 1.05rem; color: var(--gray-400); margin-bottom: 2rem; line-height: 1.75; }
.post-cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.btn-outline-light { display: inline-flex; align-items: center; gap: 8px; padding: 14px 32px; font-family: var(--font-display); font-size: .95rem; font-weight: 600; border-radius: var(--radius-full); border: 2px solid rgba(255,255,255,.25); color: white; text-decoration: none; white-space: nowrap; transition: all .3s var(--ease); }
.btn-outline-light:hover { border-color: rgba(255,255,255,.6); background: rgba(255,255,255,.08); transform: translateY(-2px); }
.section-label.light { color: var(--blue-400); justify-content: center; }
.section-label.light::before { background: var(--blue-400); }
@media (max-width: 1024px) { .post-layout { grid-template-columns: 1fr; gap: 0; } .post-sidebar { position: static; order: -1; margin-bottom: 2.5rem; } .toc-card { display: none; } .related-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 768px) { .post-header { padding: 100px 0 2.5rem; } .post-layout { grid-template-columns: 1fr; } .related-grid { grid-template-columns: 1fr; } .author-box { flex-direction: column; gap: 1rem; } .post-cta-actions { flex-direction: column; align-items: center; } .share-btn { padding: 5px 10px; font-size: .75rem; } .mid-cta { padding: 1.5rem 1.25rem; } }
</style>

<script>
  const article = document.getElementById('post-article') as HTMLElement | null;
  const tocNav  = document.getElementById('toc-nav') as HTMLElement | null;
  if (article && tocNav) {
    const headings = article.querySelectorAll<HTMLHeadingElement>('h2, h3');
    headings.forEach((heading, index) => {
      if (!heading.id) { heading.id = (heading.textContent || '').toLowerCase().replace(/[^a-z0-9\s]/g, '').replace(/\s+/g, '-').slice(0, 60) || `heading-${index}`; }
      const link = document.createElement('a');
      link.href = `#${heading.id}`; link.textContent = heading.textContent || '';
      link.className = heading.tagName === 'H3' ? 'toc-link toc-h3' : 'toc-link';
      link.addEventListener('click', (e) => { e.preventDefault(); const target = document.getElementById(heading.id); if (target) { window.scrollTo({ top: target.getBoundingClientRect().top + window.scrollY - 96, behavior: 'smooth' }); } });
      tocNav.appendChild(link);
    });
    const tocLinks = tocNav.querySelectorAll<HTMLAnchorElement>('.toc-link');
    const headingArray = Array.from(headings) as HTMLHeadingElement[];
    function updateActiveToc() { let activeId = headingArray.length > 0 ? headingArray[0].id : ''; for (let i = headingArray.length - 1; i >= 0; i--) { if (headingArray[i].getBoundingClientRect().top <= 110) { activeId = headingArray[i].id; break; } } tocLinks.forEach(l => { l.classList.toggle('active', l.getAttribute('href') === `#${activeId}`); }); }
    window.addEventListener('scroll', updateActiveToc, { passive: true }); updateActiveToc();
  }
  const pageUrl = encodeURIComponent(window.location.href); const pageTitle = encodeURIComponent(document.title);
  const shareMap: Record<string, string> = { 'share-whatsapp': `https://wa.me/?text=${pageTitle}%20${pageUrl}`, 'share-linkedin': `https://www.linkedin.com/sharing/share-offsite/?url=${pageUrl}`, 'share-x': `https://twitter.com/intent/tweet?text=${pageTitle}&url=${pageUrl}`, 'share-facebook': `https://www.facebook.com/sharer/sharer.php?u=${pageUrl}` };
  ['share-top', 'share-bottom'].forEach(groupId => { const group = document.getElementById(groupId); if (!group) return; Object.entries(shareMap).forEach(([cls, url]) => { const btn = group.querySelector<HTMLAnchorElement>(`.${cls}`); if (btn) btn.href = url; }); });
</script>

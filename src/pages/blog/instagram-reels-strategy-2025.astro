.toc-title { font-family: var(--font-display); font-size: 1.1rem; font-weight: 800; color: var(--gray-900); margin-bottom: 1.25rem; }
.toc-nav { display: flex; flex-direction: column; max-height: 380px; overflow-y: auto; scrollbar-width: thin; scrollbar-color: var(--blue-300) transparent; padding-right: 4px; }
.toc-nav::-webkit-scrollbar { width: 4px; }
.toc-nav::-webkit-scrollbar-track { background: transparent; }
.toc-nav::-webkit-scrollbar-thumb { background: var(--blue-300); border-radius: 99px; }
:global(.toc-link) { display: block; font-size: .9rem; color: var(--gray-700); padding: 13px 0; border-bottom: 1.5px solid #CBD5E1; text-decoration: none; line-height: 1.45; transition: color .2s ease; flex-shrink: 0; }
:global(.toc-link:last-child) { border-bottom: none; padding-bottom: 0; }
:global(.toc-link:hover) { color: var(--blue-600); }
:global(.toc-link.active) { color: var(--blue-600); font-weight: 700; }
:global(.toc-link.toc-h3) { padding-left: 1rem; font-size: .86rem; color: var(--gray-500); }
.sidebar-cta { background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%); border-radius: var(--radius-lg); padding: 1.75rem 1.5rem; text-align: center; }
.sidebar-cta-icon { font-size: 2rem; margin-bottom: .75rem; }
.sidebar-cta h4 { font-family: var(--font-display); font-size: 1.05rem; font-weight: 800; color: white; margin-bottom: .5rem; }

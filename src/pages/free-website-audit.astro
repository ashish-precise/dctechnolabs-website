---
import PageLayout from '../layouts/PageLayout.astro';
import CtaBanner from '../components/CtaBanner.astro';
---

<PageLayout
  title="Free Website Audit | Get a Detailed Analysis of Your Website | DC technolabs"
  description="Get a free, detailed website audit from DC technolabs. We analyse your site's SEO, speed, mobile experience, and conversion potential. No obligation. Ahmedabad-based agency."
  canonical="https://dctechnolabs.in/free-website-audit"
>

<!-- ══════════════════════════════════════════════
     SECTION 1: HERO + FORM
════════════════════════════════════════════════ -->
<section class="audit-hero" id="audit-form">
  <div class="container">
    <div class="audit-hero-grid">

      <!-- Left: Content -->
      <div class="audit-hero-content">
        <span class="section-label">Free Website Audit</span>
        <h1>Find Out <span class="highlight">What's Holding Your Website Back</span></h1>
        <p>Most Ahmedabad business websites have at least 5 critical issues costing them leads every day. We'll identify every one of them, completely free, no obligation, no sales pitch.</p>

        <div class="audit-what-you-get">
          <div class="audit-get-item">
            <span class="audit-get-icon">🔍</span>
            <div>
              <strong>Full SEO Analysis</strong>
              <p>Keyword rankings, on-page issues, technical errors, and missed opportunities</p>
            </div>
          </div>
          <div class="audit-get-item">
            <span class="audit-get-icon">⚡</span>
            <div>
              <strong>Page Speed Report</strong>
              <p>Mobile and desktop load times with specific improvements identified</p>
            </div>
          </div>
          <div class="audit-get-item">
            <span class="audit-get-icon">📱</span>
            <div>
              <strong>Mobile Experience Review</strong>
              <p>How your site performs for mobile users, 75% of India's internet traffic</p>
            </div>
          </div>
          <div class="audit-get-item">
            <span class="audit-get-icon">🎯</span>
            <div>
              <strong>Conversion Analysis</strong>
              <p>Why visitors leave without contacting you, and what to fix first</p>
            </div>
          </div>
        </div>

        <div class="audit-proof">
          <div class="audit-proof-stat"><strong>945+</strong><span>Audits Completed</span></div>
          <div class="audit-proof-stat"><strong>48 hrs</strong><span>Delivery Time</span></div>
          <div class="audit-proof-stat"><strong>100%</strong><span>Free, No Catch</span></div>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="audit-form-card">
        <h2>Request Your Free Audit</h2>
        <p>Fill in the form and we'll send your audit report within 48 hours.</p>
        <form
          class="audit-form"
          id="auditForm"
        >
          <input type="hidden" name="access_key" value="0141be72-7ed9-4e67-bd38-e0154c164ba6" />
          <input type="hidden" name="subject" value="Free Website Audit Request - DC technolabs" />

          <div class="form-group">
            <label for="audit-name">Your Name *</label>
            <input type="text" id="audit-name" name="name" placeholder="Rajesh Patel" required />
          </div>
          <div class="form-group">
            <label for="audit-phone">WhatsApp / Phone *</label>
            <input type="tel" id="audit-phone" name="phone" placeholder="+91 98765 43210" required />
          </div>
          <div class="form-group">
            <label for="audit-email">Email Address *</label>
            <input type="email" id="audit-email" name="email" placeholder="you@company.com" required />
          </div>
          <div class="form-group">
            <label for="audit-website">Your Website URL *</label>
            <input type="url" id="audit-website" name="website" placeholder="https://yourwebsite.com" required />
          </div>
          <div class="form-group">
            <label for="audit-business">Type of Business</label>
            <select id="audit-business" name="business_type">
              <option value="">Select your industry</option>
              <option>Healthcare / Clinic</option>
              <option>Real Estate / Construction</option>
              <option>Education / Coaching</option>
              <option>E-commerce / Retail</option>
              <option>Manufacturing / Industrial</option>
              <option>Restaurant / Hospitality</option>
              <option>Professional Services (Law, Finance, CA)</option>
              <option>SaaS / Technology</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="audit-goal">What's your main goal?</label>
            <select id="audit-goal" name="goal">
              <option value="">Select a goal</option>
              <option>Get more leads from my website</option>
              <option>Rank higher on Google</option>
              <option>Improve website speed</option>
              <option>Understand what's wrong with my current site</option>
              <option>Just curious to see how it scores</option>
            </select>
          </div>

          <button type="submit" class="btn btn-primary btn-full">
            Get My Free Website Audit →
          </button>
          <p class="form-reassurance">You'll receive your audit report within 48 hours. No sales call, no obligation.</p>
          <div id="auditFormMsg" class="form-msg" style="display:none"></div>
        </form>
      </div>

    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     SECTION 2: TRUST BAR
════════════════════════════════════════════════ -->
<section class="trust-bar">
  <div class="container">
    <div class="trust-bar-inner">
      <div class="trust-item">
        <div class="trust-num">945+</div>
        <div class="trust-label">Audits Delivered</div>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <div class="trust-num">4.9/5</div>
        <div class="trust-label">Average Rating</div>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <div class="trust-num">48 hrs</div>
        <div class="trust-label">Guaranteed Delivery</div>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <div class="trust-num">100%</div>
        <div class="trust-label">No Obligation</div>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <div class="trust-num">7+</div>
        <div class="trust-label">Years in Ahmedabad</div>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     SECTION 3: WHAT WE CHECK
════════════════════════════════════════════════ -->
<section class="audit-checks reveal">
  <div class="container">
    <div class="section-header centered">
      <span class="section-label">What's Covered</span>
      <h2 class="section-title">25-Point Website Audit Checklist</h2>
      <p class="section-subtitle">Every audit covers all of these. You receive a plain-language report explaining each finding and what to do about it.</p>
    </div>
    <div class="audit-checks-grid">

      <div class="audit-check-group acg--blue">
        <div class="acg-header">
          <div class="acg-icon-wrap">🔍</div>
          <h3 class="acg-title">SEO & Visibility</h3>
          <p class="acg-count">7 checkpoints</p>
        </div>
        <ul class="acg-list">
          <li>Google indexing status</li>
          <li>Title tags and meta descriptions</li>
          <li>Header structure (H1, H2, H3)</li>
          <li>Image alt text</li>
          <li>Local SEO signals</li>
          <li>Google Business Profile linkage</li>
          <li>XML sitemap presence and quality</li>
        </ul>
      </div>

      <div class="audit-check-group acg--amber">
        <div class="acg-header">
          <div class="acg-icon-wrap">⚡</div>
          <h3 class="acg-title">Speed & Performance</h3>
          <p class="acg-count">6 checkpoints</p>
        </div>
        <ul class="acg-list">
          <li>Google PageSpeed score (mobile + desktop)</li>
          <li>Core Web Vitals (LCP, FID, CLS)</li>
          <li>Image sizes and formats</li>
          <li>JavaScript and CSS bloat</li>
          <li>Hosting performance check</li>
          <li>Caching setup</li>
        </ul>
      </div>

      <div class="audit-check-group acg--green">
        <div class="acg-header">
          <div class="acg-icon-wrap">📱</div>
          <h3 class="acg-title">Mobile Experience</h3>
          <p class="acg-count">5 checkpoints</p>
        </div>
        <ul class="acg-list">
          <li>Mobile responsiveness (all breakpoints)</li>
          <li>Touch target sizes (tap friendliness)</li>
          <li>Mobile load time</li>
          <li>Text readability on small screens</li>
          <li>Mobile CTA visibility</li>
        </ul>
      </div>

      <div class="audit-check-group acg--purple">
        <div class="acg-header">
          <div class="acg-icon-wrap">🎯</div>
          <h3 class="acg-title">Conversions & UX</h3>
          <p class="acg-count">7 checkpoints</p>
        </div>
        <ul class="acg-list">
          <li>Above-the-fold clarity</li>
          <li>Call-to-action visibility and placement</li>
          <li>Contact form presence and function</li>
          <li>Trust signals (testimonials, awards)</li>
          <li>Navigation logic and ease of use</li>
          <li>Bounce rate estimate and causes</li>
          <li>Lead capture flow review</li>
        </ul>
      </div>

    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     SECTION 4: HOW IT WORKS
════════════════════════════════════════════════ -->
<section class="how-it-works reveal">
  <div class="container">
    <div class="section-header centered">
      <span class="section-label">Simple Process</span>
      <h2 class="section-title">Get Your Audit in 3 Easy Steps</h2>
      <p class="section-subtitle">No technical knowledge required. No back-and-forth emails. Just submit the form and we take care of everything.</p>
    </div>
    <div class="hiw-steps">
      <div class="hiw-step">
        <div class="hiw-num">1</div>
        <div class="hiw-content">
          <h3>Submit Your Website URL</h3>
          <p>Fill in the form above with your name, contact details, and website URL. Takes less than 2 minutes. No login, no signup, no payment required.</p>
        </div>
      </div>
      <div class="hiw-connector"></div>
      <div class="hiw-step">
        <div class="hiw-num">2</div>
        <div class="hiw-content">
          <h3>We Run the 25-Point Audit</h3>
          <p>Our team manually reviews your site across SEO, speed, mobile experience, and conversions. We use Google PageSpeed, Search Console data, and hands-on review. No automated reports.</p>
        </div>
      </div>
      <div class="hiw-connector"></div>
      <div class="hiw-step">
        <div class="hiw-num">3</div>
        <div class="hiw-content">
          <h3>Receive Your PDF Report</h3>
          <p>Within 48 hours, you'll receive a plain-language PDF report by email. Every issue is rated by severity (critical, important, minor) with a specific recommendation for what to do about it.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     SECTION 5: WHAT YOU'LL RECEIVE
════════════════════════════════════════════════ -->
<section class="audit-deliverable reveal">
  <div class="container">
    <div class="audit-deliverable-grid">
      <div class="audit-deliverable-content">
        <span class="section-label">The Deliverable</span>
        <h2 class="section-title">What Your Audit Report Looks Like</h2>
        <p>We send a clear, jargon-free PDF report covering every finding. Each issue is explained in plain language, rated by severity (critical, important, minor), and given a specific recommendation for what to do about it.</p>
        <p>You'll know exactly what's working, what's broken, and, most importantly, what to fix first for maximum impact on your visibility and lead generation.</p>
        <p>There's no obligation to hire us. Many businesses use our audit report to brief their existing web team or agency. That's fine with us.</p>
      </div>
      <div class="audit-deliverable-preview">
        <div class="audit-report-mockup">
          <div class="report-header">
            <div class="report-logo">DC technolabs</div>
            <div class="report-title">Website Audit Report</div>
            <div class="report-domain">yourwebsite.com</div>
          </div>
          <div class="report-score-row">
            <div class="report-score-item">
              <div class="score-circle score-bad">42</div>
              <span>SEO Score</span>
            </div>
            <div class="report-score-item">
              <div class="score-circle score-mid">61</div>
              <span>Speed</span>
            </div>
            <div class="report-score-item">
              <div class="score-circle score-bad">38</div>
              <span>Mobile</span>
            </div>
            <div class="report-score-item">
              <div class="score-circle score-mid">55</div>
              <span>Conversions</span>
            </div>
          </div>
          <div class="report-issues">
            <div class="report-issue report-issue--critical">🔴 3 Critical Issues Found</div>
            <div class="report-issue report-issue--warning">🟡 8 Important Improvements</div>
            <div class="report-issue report-issue--info">🟢 4 Minor Enhancements</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     SECTION 6: WHO IS THIS FOR
════════════════════════════════════════════════ -->
<section class="who-its-for reveal">
  <div class="container">
    <div class="section-header centered">
      <span class="section-label">Is This Right For You?</span>
      <h2 class="section-title">Who Benefits Most From This Audit</h2>
    </div>
    <div class="wif-grid">
      <div class="wif-card">
        <div class="wif-icon">🏪</div>
        <h3>Business Owners Getting Zero Leads From Their Website</h3>

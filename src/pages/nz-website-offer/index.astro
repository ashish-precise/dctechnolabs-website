<style>
/* ── Page-specific styles (global.css is already loaded via BaseLayout) ── */

/* ── Minimal Header ─────────────────────────────────────────── */
.lp-header {
  background: var(--white);
  border-bottom: 1px solid var(--gray-100);
  padding: 1rem 0;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 8px rgba(15,23,42,0.06);
}
.lp-header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.lp-logo {
  font-family: var(--font-display);
  font-size: 1.3rem;
  font-weight: 800;
  color: var(--blue-600);
}
.lp-logo span { color: var(--gray-900); }
.lp-header-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  background: var(--blue-600);
  color: var(--white);
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 0.9rem;
  padding: 0.6rem 1.4rem;
  border-radius: var(--radius-full);
  text-decoration: none;
  transition: all 0.3s var(--ease);
  white-space: nowrap;
}
.lp-header-cta:hover { background: var(--blue-700); transform: translateY(-1px); }

/* ── Hero ───────────────────────────────────────────────────── */
.nz-hero {
  background: linear-gradient(135deg, var(--blue-950) 0%, var(--gray-900) 60%, #1a1a2e 100%);
  color: var(--white);
  padding: clamp(3.5rem, 7vw, 6rem) 0;
  position: relative;
  overflow: hidden;
}
.nz-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 20% 50%, rgba(37,99,235,0.15) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(245,158,11,0.08) 0%, transparent 40%);
  pointer-events: none;
}
.nz-hero-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: start;
  position: relative;
}
.nz-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(37,99,235,0.15);
  border: 1px solid rgba(37,99,235,0.3);
  color: var(--blue-300);
  font-family: var(--font-display);
  font-size: 0.85rem;
  font-weight: 600;
  padding: 0.4rem 1rem;
  border-radius: var(--radius-full);
  margin-bottom: 1.5rem;
  letter-spacing: 0.02em;
}
.nz-hero h1 { color: var(--white); margin-bottom: 1.25rem; font-size: clamp(2.2rem, 4.5vw, 3.2rem); }
.nz-hero h1 .highlight { color: var(--accent); }
.nz-hero-sub {
  font-size: 1.1rem;
  color: var(--gray-300);
  margin-bottom: 2rem;
  line-height: 1.7;
}
.offer-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  background: rgba(245,158,11,0.12);
  border: 1.5px solid rgba(245,158,11,0.35);
  border-radius: var(--radius);
  padding: 0.75rem 1.25rem;
  margin-bottom: 2rem;
  flex-wrap: wrap;
}
.offer-badge .original {
  font-size: 1rem;
  color: var(--gray-400);
  text-decoration: line-through;
  font-family: var(--font-display);
}
.offer-badge .discounted {
  font-size: 1.7rem;
  font-weight: 800;
  color: var(--accent);
  font-family: var(--font-display);
  line-height: 1;
}
.offer-badge .save-tag {
  background: var(--accent);
  color: var(--black);
  font-size: 0.75rem;
  font-weight: 700;
  padding: 0.25rem 0.65rem;
  border-radius: var(--radius-full);
  font-family: var(--font-display);
}
.btn-hero-accent {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: var(--accent);
  color: var(--black);
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.05rem;
  padding: 1rem 2.25rem;
  border-radius: var(--radius-full);
  text-decoration: none;
  transition: all 0.3s var(--ease);
  box-shadow: 0 6px 20px rgba(245,158,11,0.35);
  margin-bottom: 1rem;
}
.btn-hero-accent:hover { background: var(--accent-dark); transform: translateY(-2px); box-shadow: 0 10px 28px rgba(245,158,11,0.45); }
.hero-trust-micro {
  font-size: 0.85rem;
  color: var(--gray-400);
  display: flex;
  align-items: center;
  gap: 0.4rem;
}
.nz-hero-stats {
  display: flex;
  gap: 2rem;
  margin-top: 2.5rem;
  padding-top: 2rem;
  border-top: 1px solid rgba(255,255,255,0.08);
}
.nz-hero-stat-num {
  font-family: var(--font-display);
  font-size: 1.6rem;
  font-weight: 800;
  color: var(--white);
  line-height: 1;
}
.nz-hero-stat-lbl { font-size: 0.8rem; color: var(--gray-400); margin-top: 0.2rem; }

/* ── Hero Form Card ─────────────────────────────────────────── */
.hero-form-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: 2.25rem 2rem;
  box-shadow: 0 20px 60px rgba(0,0,0,0.35);
  color: var(--gray-900);
}
.hero-form-card h3 { font-size: 1.2rem; color: var(--gray-900); margin-bottom: 0.3rem; }
.hero-form-card > p { font-size: 0.9rem; color: var(--gray-500); margin-bottom: 1.5rem; }
.form-group { margin-bottom: 1rem; }
.form-group label {
  display: block;
  font-family: var(--font-display);
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--gray-700);
  margin-bottom: 0.35rem;
}
.nz-form-input {
  width: 100%;
  padding: 0.7rem 1rem;
  border: 1.5px solid var(--gray-200);
  border-radius: var(--radius);
  font-family: var(--font-body);
  font-size: 0.95rem;
  color: var(--gray-900);
  background: var(--gray-50);
  transition: all 0.2s;
  appearance: none;
}
.nz-form-input:focus {
  outline: none;
  border-color: var(--blue-500);
  background: var(--white);
  box-shadow: 0 0 0 3px rgba(37,99,235,0.08);
}
select.nz-form-input { cursor: pointer; }
.btn-form-primary {
  width: 100%;
  padding: 0.95rem 1.5rem;
  background: var(--blue-600);
  color: var(--white);
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1rem;
  border: none;
  border-radius: var(--radius-full);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  transition: all 0.3s var(--ease);
  box-shadow: 0 4px 14px rgba(37,99,235,0.25);
  margin-top: 0.25rem;
}
.btn-form-primary:hover { background: var(--blue-700); transform: translateY(-1px); }
.form-privacy {
  font-size: 0.78rem;
  color: var(--gray-400);
  text-align: center;
  margin-top: 0.75rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.35rem;
}
.nz-form-msg {
  margin-top: 1rem;
  padding: 0.9rem 1.1rem;
  border-radius: var(--radius);
  font-size: 0.9rem;
  font-weight: 600;
  font-family: var(--font-display);
}
.nz-form-msg.success { background: #d1fae5; color: #065f46; border: 1px solid #6ee7b7; }
.nz-form-msg.error { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }

/* ── Urgency Strip ──────────────────────────────────────────── */
.urgency-strip {
  background: linear-gradient(90deg, #d97706 0%, #f59e0b 100%);
  padding: 0.9rem 0;
  text-align: center;
}
.urgency-strip p {
  color: var(--black);
  font-family: var(--font-display);
  font-weight: 700;
  font-size: clamp(0.85rem, 1.5vw, 1rem);
}

/* ── Offer Comparison ───────────────────────────────────────── */
.offer-compare {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  margin-bottom: 2.5rem;
}
.compare-card {
  border-radius: var(--radius-lg);
  padding: 1.75rem;
  border: 2px solid;
}
.compare-card.them { background: var(--gray-50); border-color: var(--gray-200); }
.compare-card.us {
  background: linear-gradient(135deg, var(--blue-50) 0%, #dbeafe 100%);
  border-color: var(--blue-400);
  position: relative;
  overflow: hidden;
}
.compare-card.us::after {
  content: 'BEST VALUE';
  position: absolute;
  top: 0.85rem;
  right: -2rem;
  background: var(--blue-600);
  color: var(--white);
  font-size: 0.65rem;
  font-weight: 700;
  font-family: var(--font-display);
  letter-spacing: 0.08em;
  padding: 0.3rem 3rem;
  transform: rotate(30deg);
}
.compare-label {
  font-family: var(--font-display);
  font-size: 0.8rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 0.5rem;
}
.compare-card.them .compare-label { color: var(--gray-500); }
.compare-card.us .compare-label { color: var(--blue-600); }
.compare-price {
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 800;
  line-height: 1;
  margin-bottom: 0.25rem;
}
.compare-card.them .compare-price { color: var(--gray-400); text-decoration: line-through; }
.compare-card.us .compare-price { color: var(--blue-700); }
.compare-note { font-size: 0.85rem; }
.compare-card.them .compare-note { color: var(--gray-500); }
.compare-card.us .compare-note { color: var(--blue-600); font-weight: 600; }
.compare-list { margin-top: 1rem; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
.compare-list li { font-size: 0.85rem; }
.saving-callout {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border: 1.5px solid var(--accent);
  border-radius: var(--radius);
  padding: 1.25rem 1.5rem;
  margin-bottom: 2.5rem;
  text-align: center;
}
.saving-callout p {
  color: #92400e;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1rem;
}

/* ── Features Grid ──────────────────────────────────────────── */
.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.875rem;
}
.feature-item {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  padding: 1rem 1.1rem;
  background: var(--white);
  border: 1.5px solid var(--gray-100);
  border-radius: var(--radius);
  transition: all 0.3s var(--ease);
}
.feature-item:hover { border-color: var(--blue-200); box-shadow: 0 4px 14px rgba(37,99,235,0.07); transform: translateY(-2px); }
.feature-check {
  width: 22px;
  height: 22px;
  background: linear-gradient(135deg, #10b981, #059669);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 0.1rem;
  box-shadow: 0 2px 6px rgba(16,185,129,0.3);
}
.feature-check svg { color: white; }
.feature-text {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 0.88rem;
  color: var(--gray-700);
  line-height: 1.4;
}

/* ── Persona Cards ──────────────────────────────────────────── */
.persona-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
}
.persona-card {
  background: var(--white);
  border: 1.5px solid var(--gray-100);
  border-radius: var(--radius-lg);
  padding: 2rem 1.75rem;
  transition: all 0.3s var(--ease);
  position: relative;
  overflow: hidden;
}
.persona-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--blue-600), var(--blue-400));
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.35s var(--ease);
}
.persona-card:hover { transform: translateY(-5px); box-shadow: 0 16px 48px rgba(15,23,42,0.1); }
.persona-card:hover::before { transform: scaleX(1); }
.persona-icon-wrap {
  width: 56px;
  height: 56px;
  border-radius: 16px;
  background: var(--blue-50);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.75rem;
  margin-bottom: 1.25rem;
}
.persona-card h4 { font-size: 1rem; margin-bottom: 0.75rem; color: var(--gray-900); }
.persona-divider {
  width: 32px;
  height: 2px;
  background: var(--blue-200);
  border-radius: 2px;
  margin-bottom: 0.75rem;
}
.persona-pain {
  font-size: 0.85rem;
  color: var(--gray-500);
  margin-bottom: 0.75rem;
  font-style: italic;
  line-height: 1.55;
}
.persona-win {
  font-size: 0.875rem;
  color: var(--blue-700);
  font-weight: 600;
  font-family: var(--font-display);
  line-height: 1.45;
  display: flex;
  align-items: flex-start;
  gap: 0.4rem;
}
.persona-win::before { content: '→'; flex-shrink: 0; }

/* ── Lead Capture Form Section ──────────────────────────────── */
.lead-form-section {
  background: linear-gradient(135deg, var(--blue-950) 0%, var(--gray-900) 100%);
  padding: clamp(3.5rem, 7vw, 6rem) 0;
  position: relative;
  overflow: hidden;
}
.lead-form-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 70% 50%, rgba(37,99,235,0.12) 0%, transparent 60%);
  pointer-events: none;
}
.lead-form-inner {
  max-width: 700px;
  margin: 0 auto;
  text-align: center;
  position: relative;
}
.lead-form-inner h2 { color: var(--white); margin-bottom: 0.75rem; }
.lead-form-inner > p { color: var(--gray-300); font-size: 1.05rem; margin-bottom: 2.5rem; }
.lead-form-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: 2.5rem 2.25rem;
  box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  text-align: left;
}
.form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.btn-lead {
  width: 100%;
  padding: 1.1rem 1.5rem;
  background: var(--blue-600);
  color: var(--white);
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.05rem;
  border: none;
  border-radius: var(--radius-full);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  transition: all 0.3s var(--ease);
  box-shadow: 0 4px 14px rgba(37,99,235,0.25);
  margin-top: 0.25rem;
}
.btn-lead:hover { background: var(--blue-700); transform: translateY(-1px); }

/* ── Final CTA ──────────────────────────────────────────────── */
.final-cta-dark {
  background: linear-gradient(135deg, #1e3a5f 0%, #1a1a2e 100%);
  padding: clamp(3.5rem, 7vw, 6rem) 0;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.final-cta-dark::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 30% 50%, rgba(37,99,235,0.12) 0%, transparent 50%),
    radial-gradient(circle at 70% 50%, rgba(245,158,11,0.07) 0%, transparent 50%);
  pointer-events: none;
}
.final-cta-dark h2 { color: var(--white); margin-bottom: 0.75rem; position: relative; }
.final-cta-dark p { color: var(--gray-300); font-size: 1.05rem; position: relative; }
.final-cta-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  justify-content: center;
  margin-top: 2rem;
  position: relative;
}
.btn-cta-accent {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: var(--accent);
  color: var(--black);
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.05rem;
  padding: 1rem 2.25rem;
  border-radius: var(--radius-full);
  text-decoration: none;
  transition: all 0.3s var(--ease);
  box-shadow: 0 6px 20px rgba(245,158,11,0.35);
}
.btn-cta-accent:hover { background: var(--accent-dark); transform: translateY(-2px); }
.btn-cta-outline {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: transparent;
  color: var(--white);
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 1.05rem;
  padding: 1rem 2.25rem;
  border-radius: var(--radius-full);
  text-decoration: none;
  border: 1.5px solid rgba(255,255,255,0.3);
  transition: all 0.3s var(--ease);
}
.btn-cta-outline:hover { border-color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.06); }

/* ── Minimal Footer ─────────────────────────────────────────── */
.lp-footer {
  background: var(--gray-900);
  padding: 2rem 0;
  text-align: center;
  border-top: 1px solid rgba(255,255,255,0.06);
}
.lp-footer-inner { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; }
.lp-footer-logo { font-family: var(--font-display); font-size: 1.1rem; font-weight: 800; color: var(--blue-400); }
.lp-footer-tagline { font-size: 0.85rem; color: var(--gray-500); }
.lp-footer-links { display: flex; gap: 1.5rem; flex-wrap: wrap; justify-content: center; }
.lp-footer-links a { font-size: 0.8rem; color: var(--gray-500); transition: color 0.2s; text-decoration: none; }
.lp-footer-links a:hover { color: var(--gray-300); }
.lp-footer-copy { font-size: 0.78rem; color: var(--gray-600); }

/* ── Responsive ─────────────────────────────────────────────── */
@media (max-width: 1024px) {
  .persona-grid { grid-template-columns: repeat(2, 1fr); }
  .features-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 768px) {
  .nz-hero-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  .offer-compare { grid-template-columns: 1fr; }
  .form-row-2 { grid-template-columns: 1fr; }
  .nz-hero-stats { gap: 1.25rem; }
  .lead-form-card { padding: 1.75rem 1.25rem; }
  .process-steps { grid-template-columns: 1fr !important; }
  .process-step::after { display: none !important; }
}
@media (max-width: 600px) {
  .persona-grid { grid-template-columns: 1fr; }
  .features-grid { grid-template-columns: 1fr 1fr; }
  .final-cta-btns { flex-direction: column; align-items: center; }
}
@media (max-width: 380px) {
  .features-grid { grid-template-columns: 1fr; }
}
</style>

<!-- ─── MINIMAL HEADER ───────────────────────────────────────────── -->
<header class="lp-header">
  <div class="container">
    <div class="lp-header-inner">
      <div class="lp-logo">DC<span>Technolabs</span></div>
      <a href="#claim-offer" class="lp-header-cta">
        Claim $150 Off
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>
</header>

<main>

<!-- ════════════════════════════════════════════
     SECTION 1: HERO
═════════════════════════════════════════════ -->
<section class="nz-hero">
  <div class="container">
    <div class="nz-hero-grid">

      <!-- Left -->
      <div>
        <div class="nz-eyebrow">Exclusive Offer for New Zealand Businesses</div>

        <h1>Get a Professional Website<br>for <span class="highlight">NZD $500</span></h1>

        <p class="nz-hero-sub">Save $150 on a fast, mobile-ready website built for your NZ business. No GST. No hidden fees. Limited spots available this month.</p>

        <div class="offer-badge">
          <span class="original">NZD $650</span>
          <span class="discounted">NZD $500</span>
          <span class="save-tag">SAVE $150</span>
        </div>

        <div>
          <a href="#claim-offer" class="btn-hero-accent">
            Claim My $150 Discount
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>

        <p class="hero-trust-micro">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          No obligation. Free consultation. Response within 1 business day.
        </p>


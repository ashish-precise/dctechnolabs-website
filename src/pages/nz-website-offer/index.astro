---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Professional Website Design for NZD $500 | DC Technolabs"
  description="Get a professional, mobile-ready website for your NZ business for just NZD $500. Save $150 — limited time offer. No GST. No hidden fees. Fast turnaround."
  canonical="https://dctechnolabs.in/nz-website-offer"
>


<!-- ════════════════════════════════════════════
     SCRIPTS
═════════════════════════════════════════════ -->
<script is:inline>
  (function() {
    /* ── FAQ Accordion ─────────────────────── */
    document.querySelectorAll('.faq-question').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var item = this.closest('.faq-item');
        var isOpen = item.classList.contains('open');
        document.querySelectorAll('.faq-item').forEach(function(i) { i.classList.remove('open'); });
        if (!isOpen) item.classList.add('open');
      });
    });

    /* ── Counter Animation ─────────────────── */
    var countersRun = false;
    function runCounters() {
      if (countersRun) return;
      countersRun = true;
      document.querySelectorAll('.counter').forEach(function(el) {
        var target = parseInt(el.getAttribute('data-target'), 10);
        if (isNaN(target)) return;
        var inc = target / (1800 / 16);
        var cur = 0;
        var t = setInterval(function() {
          cur += inc;
          if (cur >= target) { el.textContent = target; clearInterval(t); }
          else { el.textContent = Math.floor(cur); }
        }, 16);
      });
    }
    if ('IntersectionObserver' in window) {
      var statsBar = document.querySelector('.stats-bar');
      if (statsBar) {
        new IntersectionObserver(function(entries, obs) {
          entries.forEach(function(e) { if (e.isIntersecting) { runCounters(); obs.unobserve(e.target); } });
        }, { threshold: 0.2 }).observe(statsBar);
      }
    } else { runCounters(); }

    /* ── Web3Forms Handler ─────────────────── */
    function handleForm(formId, msgId) {
      var form = document.getElementById(formId);
      if (!form) return;
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        var btn = form.querySelector('button[type="submit"]');
        var msgEl = document.getElementById(msgId);
        var orig = btn.innerHTML;
        btn.disabled = true;
        btn.textContent = 'Sending...';
        try {
          var res = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: new FormData(form) });
          var json = await res.json();
          msgEl.style.display = 'block';
          if (json.success) {
            msgEl.className = 'nz-form-msg success';
            msgEl.textContent = "Thank you! We've received your enquiry and will be in touch within 1 business day to confirm your discount.";
            form.reset();
            if (typeof fbq !== 'undefined') fbq('track', 'Lead');
            setTimeout(function() { window.location.href = '/thank-you/'; }, 1500);
          } else {
            msgEl.className = 'nz-form-msg error';
            msgEl.textContent = 'Something went wrong. Please try again or email hello@dctechnolabs.com';
          }
        } catch(err) {
          msgEl.style.display = 'block';
          msgEl.className = 'nz-form-msg error';
          msgEl.textContent = 'Something went wrong. Please email hello@dctechnolabs.com';
        } finally {
          btn.disabled = false;
          btn.innerHTML = orig;
        }
      });
    }

    handleForm('heroNZForm', 'heroNZFormMsg');
    handleForm('mainNZForm', 'mainNZFormMsg');
  })();
</script>


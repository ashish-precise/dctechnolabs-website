<script>
  const seoAuditForm = document.getElementById('seoAuditForm') as HTMLFormElement | null;
  const seoAuditFormMsg = document.getElementById('seoAuditFormMsg') as HTMLElement | null;
  if (seoAuditForm && seoAuditFormMsg) {
    seoAuditForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = seoAuditForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (submitBtn) submitBtn.disabled = true;
      seoAuditFormMsg.style.display = 'none';
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: new FormData(seoAuditForm)
        });
        const data = await res.json();
        if (data.success) {
          if (typeof gtag !== 'undefined') { gtag('event', 'generate_lead'); }
          seoAuditFormMsg.textContent = 'Thank you! We will get back to you within 24 hours.';
          seoAuditFormMsg.className = 'form-msg form-msg--success';
          seoAuditFormMsg.style.display = 'block';
          seoAuditForm.reset();
        } else {
          throw new Error('submission failed');
        }
      } catch {
        seoAuditFormMsg.textContent = 'Something went wrong. Please try again or WhatsApp us directly.';
        seoAuditFormMsg.className = 'form-msg form-msg--error';
        seoAuditFormMsg.style.display = 'block';
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  }
</script>

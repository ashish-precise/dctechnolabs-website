---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thank You — We'll Be in Touch | DC Technolabs"
  description="Thank you for your enquiry. DC Technolabs will be in touch within 1 business day."
  canonical="https://dctechnolabs.in/thank-you"
>
<meta name="robots" content="noindex, nofollow" slot="head">

<!-- Meta Pixel Lead Conversion Event — replace YOUR_PIXEL_ID -->
<script is:inline>
  !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
  n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
  n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
  t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
  document,'script','https://connect.facebook.net/en_US/fbevents.js');
  fbq('init','1207505044881138');
  fbq('track','PageView');
  fbq('track','Lead');
</script>
<noscript><img height="1" width="1" style="display:none"
  src="https://www.facebook.com/tr?id=1207505044881138&ev=Lead&noscript=1"/></noscript>

<style>
  .ty-page {
    background: #0F172A;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.5rem;
    font-family: 'DM Sans', sans-serif;
    text-align: center;
  }

  .ty-logo {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.2rem;
    font-weight: 800;
    color: #60A5FA;
    margin-bottom: 3rem;
    letter-spacing: -0.01em;
  }

  .ty-card {
    background: #1E293B;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 24px;
    padding: clamp(2rem, 5vw, 3.5rem) clamp(1.5rem, 5vw, 3rem);
    max-width: 520px;
    width: 100%;
    box-shadow: 0 24px 80px rgba(0,0,0,0.5);
  }

  .ty-check-circle {
    width: 72px;
    height: 72px;
    background: linear-gradient(135deg, #10B981, #059669);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.75rem;
    box-shadow: 0 8px 30px rgba(16,185,129,0.4);
  }

  .ty-card h1 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .ty-card h1 span { color: #F59E0B; }

  .ty-card > p {
    font-size: 1rem;
    color: #94A3B8;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .ty-steps {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-align: left;
    margin-bottom: 2rem;
  }

  .ty-step {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
    padding: 1rem 1.1rem;
  }

  .ty-step-num {
    width: 28px;
    height: 28px;
    min-width: 28px;
    background: #2563EB;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    color: #fff;
  }

  .ty-step-text { font-size: 0.9rem; color: #CBD5E1; line-height: 1.55; }
  .ty-step-text strong { color: #fff; display: block; margin-bottom: 0.15rem; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.95rem; }

  .ty-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #60A5FA;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: color 0.2s;
  }
  .ty-back:hover { color: #93C5FD; }
</style>

<div class="ty-page">

  <div class="ty-logo">DC Technolabs</div>

  <div class="ty-card">

    <div class="ty-check-circle">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
    </div>

    <h1>You're All Set!<br><span>Discount Locked.</span></h1>

    <p>We've received your enquiry. One of our team members will be in touch within <strong style="color:#fff;">1 business day</strong> to confirm your NZD $150 discount and discuss your project.</p>

    <div class="ty-steps">
      <div class="ty-step">
        <div class="ty-step-num">1</div>
        <div class="ty-step-text">
          <strong>Check your inbox</strong>
          A confirmation has been sent to your email address.
        </div>
      </div>
      <div class="ty-step">
        <div class="ty-step-num">2</div>
        <div class="ty-step-text">
          <strong>We'll call or email you</strong>
          Our team will reach out within 1 business day to discuss your project.
        </div>
      </div>
      <div class="ty-step">
        <div class="ty-step-num">3</div>
        <div class="ty-step-text">
          <strong>Your discount is reserved</strong>
          We'll confirm your NZD $500 price on our call.
        </div>
      </div>
    </div>

    <a href="https://dctechnolabs.in" class="ty-back">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      Visit DC Technolabs Website
    </a>

  </div>

</div>

</BaseLayout>

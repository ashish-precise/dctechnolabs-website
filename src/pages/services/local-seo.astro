const faqItems: FaqItem[] = [
  { q: "What is local SEO and how is it different from regular SEO?", a: "Local SEO focuses on ranking your business for location-specific searches and in the Google Maps pack. Regular SEO targets broader keyword rankings. If you serve customers in a specific area of Ahmedabad, local SEO is what gets you found by nearby buyers." },
  { q: "How quickly can you get my business into the Google Maps top 3?", a: "Typically 6 to 10 weeks for less competitive areas, and 3 to 5 months for highly competitive niches like dentists or restaurants in prime Ahmedabad locations like Satellite or SG Highway. The foundation work is fast, but Map Pack rankings depend on competition." },
  { q: "What is a Google Business Profile and why does it matter?", a: "GBP is your free Google listing that appears in Maps and local search results. An optimized GBP is the single most important factor in local search rankings. We fully manage yours every month including posts, photos, Q&A, and review responses." },
  { q: "How do you get more reviews without paying for them?", a: "We set up a review request process using WhatsApp and SMS follow-ups after each customer interaction. Genuine reviews from real customers. No fake reviews, no shortcuts. Google penalizes fake reviews and so do we." },
  { q: "Do I need a website for local SEO?", a: "You absolutely need a GBP. A website helps significantly and we optimize your existing site for local signals. If you don't have a website yet, ask about our web design service which is built for local SEO from the ground up." },
  { q: "Do you manage GBP for multiple locations?", a: "Yes. Our Multi-Location plan covers up to 3 Ahmedabad locations. Each location gets separate GBP management, location-specific keywords, and dedicated content to avoid cross-location cannibalization." },
  { q: "What Indian directories do you build citations in?", a: "JustDial, IndiaMART, Sulekha, IndiaBizInfo, Grotal, Yellow Pages India, TradeIndia, and 40+ more. We build and verify listings in every major Indian local directory and correct any wrong information we find." },
  { q: "Can you help with negative reviews?", a: "We cannot remove reviews that Google won't remove, but we help you respond professionally to every negative review and build enough positive reviews that the negatives become a small fraction of your overall rating." },
];

const relatedServices: RelatedService[] = [

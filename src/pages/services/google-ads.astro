const faqItems: FaqItem[] = [
  { q: "What is the minimum Google Ads budget I need?", a: "We recommend a minimum of ₹30,000 per month in ad spend to generate meaningful data. Below that it is hard to optimise effectively. The management fee is separate from your ad spend, which you pay directly to Google." },
  { q: "How quickly will I start getting leads?", a: "Search campaigns can start generating leads within 24 to 48 hours of launch. The first 2 weeks are used to collect performance data before making major optimizations and scaling what works." },
  { q: "Do I pay Google directly or through you?", a: "You pay Google directly. Your billing card is on your own account. We never touch your ad spend. You have full transparency and complete control over your account at all times." },
  { q: "What is ROAS and why does it matter?", a: "ROAS (Return on Ad Spend) measures how much revenue you earn per rupee spent on ads. A 5x ROAS means ₹5 earned for every ₹1 spent. We target 5x minimum and typically achieve 8x across our Ahmedabad client portfolio." },
  { q: "Can you take over my existing Google Ads account?", a: "Yes. We start with a full audit, identify wasted spend, and restructure before making any changes. We do not delete your campaign history as it contains valuable data for optimization." },
  { q: "Do you manage Facebook Ads too?", a: "Our Google Ads service is focused on Google's network. For social media advertising including Facebook and Instagram, ask about our social media marketing service." },
  { q: "What industries work best with Google Ads?", a: "Services with clear purchase intent work best: clinics, lawyers, CAs, real estate, education, home services, and B2B. E-commerce works well with Shopping Ads. We assess your specific Ahmedabad market before recommending a strategy." },
  { q: "What happens if my ads are not performing?", a: "We flag it in your weekly update, explain what we are testing, and adjust strategy. If performance does not improve after 60 days of optimization, we will tell you honestly and will not pressure you to continue." },
];


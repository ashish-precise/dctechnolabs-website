const faqItems: FaqItem[] = [
  {
    q: "Shopify or WooCommerce which one is better for an Indian business?",
    a: "Both work well in India. Shopify is easier to manage, has better uptime, and is faster to launch. WooCommerce gives you more customisation control and lower ongoing cost if you already have WordPress hosting. For most new stores we recommend Shopify because the Razorpay integration is more reliable and the mobile checkout experience is superior. We have a detailed blog post on this comparison if you want to read more."
  },
  {
    q: "Is Razorpay the only payment gateway you support?",
    a: "Razorpay is our preferred gateway because it has the most reliable Shopify integration, supports all Indian payment methods including UPI, and has excellent customer support for Indian merchants. We also support PayU, CCAvenue, and Cashfree depending on your business requirements. All gateways are configured to handle GST invoicing automatically."
  },

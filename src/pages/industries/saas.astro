const faqItems: FaqItem[] = [
  {
    q: "Can content marketing actually generate leads for a B2B SaaS product?",
    a: "Yes, and it is often the most cost-effective channel for B2B SaaS over time. Buyers of software products research extensively before purchasing. Blog posts comparing alternatives, explaining integrations, or solving specific problems attract buyers who are already in evaluation mode. These leads come with high intent and convert at much better rates than cold outreach."

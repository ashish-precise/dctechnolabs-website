const faqItems: FaqItem[] = [
  {
    q: "Do I really need my own website if I am already on IndiaMART?",
    a: "IndiaMART is a useful directory but it comes with significant limitations. You pay per-lead fees, you compete with dozens of similar suppliers on the same page, and buyers have no way to assess your quality independently. Your own website lets you control the narrative, showcase your factory, certifications, and client references, and receive enquiries at zero per-lead cost. Over 18 to 24 months, the cost savings on IndiaMART fees typically exceed the cost of your website."
  },
  {
    q: "Can a website actually help us get enquiries from buyers in the Middle East or Africa?",

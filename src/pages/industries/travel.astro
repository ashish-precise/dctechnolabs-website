const faqItems: FaqItem[] = [
  {
    q: "Can you help a small travel agency compete with MakeMyTrip or Yatra on Google?",
    a: "Yes, and the approach is different from competing on price. We position your agency as the personal, expert alternative for travellers who want someone to plan their trip properly. Pilgrimage packages, custom itineraries, and group tours are areas where aggregators cannot compete with a knowledgeable local agency."

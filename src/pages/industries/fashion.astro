const faqItems: FaqItem[] = [
  {
    q: "Is Shopify the best platform for a fashion brand selling ethnic wear in India?",
    a: "Shopify works very well for Indian fashion brands. It supports Razorpay and PayU for payments, handles GST invoicing, manages size and colour variants cleanly, and works well on mobile. For brands with straightforward catalogues, Shopify is our default recommendation. For brands with very complex customisation needs or large wholesale operations, WooCommerce may be more flexible."

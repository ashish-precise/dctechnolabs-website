const faqItems: FaqItem[] = [
  {
    q: "Can a lawyer legally advertise their services in India?",
    a: "This is the question we get asked most. Under the Bar Council of India Rules, advocates cannot solicit work or advertise in a manner that is prohibited. However, you are allowed to have a professional website that lists your name, qualifications, contact details, and areas of practice. You can also publish educational content about legal topics. What you cannot do is use slogans like 'best lawyer in Ahmedabad', make guarantees about outcomes, or use any promotional language that amounts to touting. We are fully familiar with these rules and all our work stays within them."

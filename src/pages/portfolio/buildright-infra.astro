<!-- ============================================================
  PAGE STYLES
============================================================ -->
<style>

/* Section label on dark backgrounds */
.section-label.light {
  display: block;
  text-align: center;
  color: var(--blue-300);
  margin-bottom: .75rem;
}

.section-label.light::before {
  display: none;
}

/* ---- HERO ---- */
.cs-hero {
  padding: 120px 0 0;
  background: linear-gradient(170deg, var(--white) 0%, var(--blue-50) 55%, var(--white) 100%);
  position: relative;
  overflow: hidden;
}

.cs-hero::before {
  content: '';
  position: absolute;
  top: -100px; right: -100px;
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(59,130,246,.07) 0%, transparent 70%);
  pointer-events: none;
}

.cs-breadcrumb {
  display: flex;
  align-items: center;
  gap: .5rem;
  font-size: .8rem;
  color: var(--gray-500);
  margin-bottom: 2rem;
}

.cs-breadcrumb a { color: var(--gray-500); text-decoration: none; }
.cs-breadcrumb a:hover { color: var(--blue-600); }

.cs-hero-inner {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 3rem;
  align-items: center;
  padding-bottom: 4rem;
}

.cs-meta-top {
  display: flex;
  gap: .5rem;
  margin-bottom: 1.25rem;
  flex-wrap: wrap;
}

.cs-category-pill {
  display: inline-flex;
  align-items: center;
  background: var(--blue-100);
  color: var(--blue-700);
  font-size: .75rem;
  font-weight: 700;
  letter-spacing: .06em;
  text-transform: uppercase;
  padding: .3rem .85rem;
  border-radius: 99px;
}

.cs-pill-green {
  background: #dcfce7;
  color: #166534;
}

.cs-pill-purple {
  background: #ede9fe;
  color: #5b21b6;
}

.cs-pill-orange {
  background: #ffedd5;
  color: #c2410c;
}

.cs-title {
  font-family: var(--font-display);
  font-size: clamp(1.9rem, 3.5vw, 2.75rem);
  font-weight: 900;
  line-height: 1.2;
  letter-spacing: -.025em;
  color: var(--gray-900);
  margin-bottom: 1.25rem;
  max-width: 620px;
}

.cs-excerpt {
  font-size: 1.05rem;
  color: var(--gray-600);
  line-height: 1.75;
  margin-bottom: 2rem;
  max-width: 580px;
}

.cs-hero-results {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.cs-result-pill {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: white;
  border: 1.5px solid var(--blue-200);
  border-radius: 12px;
  padding: .85rem 1.25rem;
  min-width: 80px;
  box-shadow: 0 2px 8px rgba(37,99,235,.08);
}

.cs-result-pill strong {
  font-family: var(--font-display);
  font-size: 1.4rem;
  font-weight: 900;
  color: var(--blue-600);
  line-height: 1;
  margin-bottom: .25rem;
}

.cs-result-pill span {
  font-size: .72rem;
  font-weight: 600;
  color: var(--gray-500);
  text-align: center;
  line-height: 1.3;
}

/* Browser mockup */
.cs-hero-visual { display: flex; align-items: center; justify-content: center; }

.cs-mockup {
  width: 100%;
  max-width: 320px;
  background: var(--gray-900);
  border-radius: 14px;
  overflow: hidden;
  box-shadow: 0 24px 60px rgba(0,0,0,.18);
}

.cs-mockup-bar {
  background: var(--gray-800);
  padding: .6rem 1rem;
  display: flex;
  gap: .4rem;
  align-items: center;
}

.cs-mockup-bar span {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: var(--gray-600);
}

.cs-mockup-bar span:nth-child(1) { background: #ff5f57; }

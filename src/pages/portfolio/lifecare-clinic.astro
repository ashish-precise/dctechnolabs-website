        <p class="cs-excerpt">
          A Navrangpura-based multi-speciality clinic was losing patients to competitors with better-looking, faster websites. We rebuilt their entire web presence from scratch and made them the number 1 ranked clinic in Ahmedabad local search.
        </p>

        <!-- Key results row -->
        <div class="cs-hero-results">
          <div class="cs-result-pill">
            <strong>3x</strong>
            <span>Appointments</span>
          </div>
          <div class="cs-result-pill">
            <strong>#1</strong>
            <span>Local SEO Rank</span>
          </div>
          <div class="cs-result-pill">
            <strong>96</strong>
            <span>PageSpeed Score</span>
          </div>
          <div class="cs-result-pill">
            <strong>90 days</strong>
            <span>Time to Results</span>
          </div>
        </div>
      </div>

      <!-- Project visual -->
      <div class="cs-hero-visual" aria-hidden="true">
        <div class="cs-mockup">
          <div class="cs-mockup-bar">
            <span></span><span></span><span></span>
          </div>
          <div class="cs-mockup-screen">
            <div class="cs-mockup-emoji">🏥</div>
            <div class="cs-mockup-lines">
              <div class="cs-mockup-line wide"></div>
              <div class="cs-mockup-line medium"></div>
              <div class="cs-mockup-line short"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>


<!-- ============================================================
  PROJECT META BAR
============================================================ -->
<section class="cs-meta-bar">
  <div class="container">
    <div class="cs-meta-grid">
      <div class="cs-meta-item">
        <span class="cs-meta-label">Client</span>
        <span class="cs-meta-value">LifeCare Clinic</span>
      </div>
      <div class="cs-meta-item">
        <span class="cs-meta-label">Industry</span>
        <span class="cs-meta-value">Healthcare</span>
      </div>
      <div class="cs-meta-item">
        <span class="cs-meta-label">Location</span>
        <span class="cs-meta-value">Navrangpura, Ahmedabad</span>
      </div>

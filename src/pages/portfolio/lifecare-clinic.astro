---
// src/pages/portfolio/lifecare-clinic.astro
// DC technolabs — Case Study: LifeCare Clinic, Ahmedabad
// Template for all individual portfolio / case study pages

import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout
  title="LifeCare Clinic Case Study — 3x Appointments via Website Redesign | DC technolabs"
  description="How DC technolabs redesigned LifeCare Clinic's website, achieved number 1 local SEO ranking in Ahmedabad, and tripled appointment bookings within 90 days."
  canonical="https://dctechnolabs.in/portfolio/lifecare-clinic"
>

<!-- Case Study Schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "LifeCare Clinic — 3x Appointments via Healthcare Website Redesign in Ahmedabad",
  "description": "How DC technolabs redesigned LifeCare Clinic's website, achieved number 1 local SEO ranking in Ahmedabad, and tripled appointment bookings within 90 days.",
  "author": {
    "@type": "Organization",
    "name": "DC technolabs",
    "url": "https://dctechnolabs.in"
  },
  "publisher": {
    "@type": "Organization",
    "name": "DC technolabs",
    "logo": {
      "@type": "ImageObject",
      "url": "https://dctechnolabs.in/logo.png"
    }
  },
  "datePublished": "2026-03-03",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://dctechnolabs.in/portfolio/lifecare-clinic"
  }
}
</script>


<!-- ============================================================
  CASE STUDY HERO
============================================================ -->
<section class="cs-hero">
  <div class="container">

    <!-- Breadcrumb -->
    <nav class="cs-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/portfolio">Portfolio</a>

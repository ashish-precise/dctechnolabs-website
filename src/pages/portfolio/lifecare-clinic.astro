    </div>

    <div class="cs-results-grid">
      <div class="cs-result-card">
        <div class="cs-result-number">3x</div>
        <div class="cs-result-label">Appointment Bookings</div>
        <div class="cs-result-note">Monthly online appointments went from 40 to 127 within 90 days of launch</div>
      </div>
      <div class="cs-result-card cs-result-accent">
        <div class="cs-result-number">#1</div>
        <div class="cs-result-label">Local Search Ranking</div>
        <div class="cs-result-note">Ranking first in Ahmedabad local pack for "clinic Navrangpura," "doctor Ahmedabad," and 6 other keywords</div>
      </div>
      <div class="cs-result-card">
        <div class="cs-result-number">96</div>
        <div class="cs-result-label">PageSpeed Score</div>
        <div class="cs-result-note">Up from 24 on mobile. Pages now load in 1.8 seconds on a standard 4G connection</div>
      </div>
      <div class="cs-result-card">
        <div class="cs-result-number">340%</div>
        <div class="cs-result-label">Organic Traffic Increase</div>
        <div class="cs-result-note">Monthly sessions grew from 380 to 1,672 in the first 90 days post-launch</div>
      </div>
      <div class="cs-result-card">
        <div class="cs-result-number">62%</div>
        <div class="cs-result-label">Bounce Rate Reduction</div>
        <div class="cs-result-note">Visitors now find what they need quickly and proceed to contact or book</div>
      </div>
      <div class="cs-result-card cs-result-accent">
        <div class="cs-result-number">4.8★</div>
        <div class="cs-result-label">Google Review Rating</div>
        <div class="cs-result-note">Review request system added to post-visit follow-up. Reviews grew from 34 to 91 in 90 days</div>
      </div>
    </div>
  </div>
</section>


<!-- ============================================================
  TESTIMONIAL (light bg)
============================================================ -->
<section class="cs-section cs-light">
  <div class="container">
    <div class="cs-testimonial-wrap">
      <div class="cs-quote-mark" aria-hidden="true">"</div>

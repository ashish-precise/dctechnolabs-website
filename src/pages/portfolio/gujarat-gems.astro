  display: block;
  text-align: center;
  color: var(--blue-300);
  margin-bottom: .75rem;
}

.section-label.light::before {
  display: none;
}

/* ---- HERO ---- */
.cs-hero {
  padding: 120px 0 0;
  background: linear-gradient(170deg, var(--white) 0%, var(--blue-50) 55%, var(--white) 100%);
  position: relative;
  overflow: hidden;
}

.cs-hero::before {
  content: '';
  position: absolute;
  top: -100px; right: -100px;
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(59,130,246,.07) 0%, transparent 70%);
  pointer-events: none;
}

.cs-breadcrumb {
  display: flex;
  align-items: center;
  gap: .5rem;
  font-size: .8rem;
  color: var(--gray-500);
  margin-bottom: 2rem;
}

.cs-breadcrumb a { color: var(--gray-500); text-decoration: none; }
.cs-breadcrumb a:hover { color: var(--blue-600); }

.cs-hero-inner {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 3rem;
  align-items: center;
  padding-bottom: 4rem;
}

.cs-meta-top {
  display: flex;
  gap: .5rem;
  margin-bottom: 1.25rem;
  flex-wrap: wrap;
}

.cs-category-pill {
  display: inline-flex;
  align-items: center;
  background: var(--blue-100);
  color: var(--blue-700);
  font-size: .75rem;
  font-weight: 700;
  letter-spacing: .06em;
  text-transform: uppercase;
  padding: .3rem .85rem;
  border-radius: 99px;
}

.cs-pill-green {
  background: #dcfce7;
  color: #166534;
}

.cs-pill-purple {
  background: #ede9fe;
  color: #5b21b6;
}

.cs-pill-orange {
  background: #ffedd5;
  color: #c2410c;
}

.cs-title {
  font-family: var(--font-display);
  font-size: clamp(1.9rem, 3.5vw, 2.75rem);
  font-weight: 900;
  line-height: 1.2;
  letter-spacing: -.025em;
  color: var(--gray-900);
